go

/*** USER SHOULD HAVE ACCESS TO THESE OBJECTS ***/
/*** SCHEMA ONWER AND CURRENT OWNER ARE SAME ***/
select * from object_ownership_s3.t2;
go
select * from object_ownership_s3.v2;
go
