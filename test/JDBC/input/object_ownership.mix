go
insert into object_ownership_s2.t1 values (2, 3);
go
select next value for object_ownership_s2.sq1;
go
select * from object_ownership_s2.tvf1();
go
select * from object_ownership_s2.mtvf1();
go
select * from object_ownership_s3.pt2;
go
use master
go

