    CREATE TABLE #temp (id INT, id1 AS id*2);
    ALTER TABLE #temp ADD CONSTRAINT def DEFAULT 1 FOR id1;
    SELECT * FROM babel_5448_t JOIN babel_5448_s2.babel_5448_v ON (1=1);
