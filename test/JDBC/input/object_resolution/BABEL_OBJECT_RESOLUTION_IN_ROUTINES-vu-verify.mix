/*************************************************************************************/
/***************** VERIFY DEFAULT SCHEMA OF IN BUILT USERS ***************************/
/*************************************************************************************/

SELECT database_name, orig_username, default_schema_name FROM sys.babelfish_authid_user_ext
WHERE database_name IN ('master', 'tempdb', 'msdb', 'babel_5448_db') AND
      orig_username IN ('dbo', 'guest')
ORDER BY database_name, orig_username;
GO

