-- RESET LOGIN PASSWORD
ALTER LOGIN object_ownership_l1 WITH PASSWORD = '123'
GO

create login object_ownership_l2 with password = '123'
go
use object_ownership_db;
go
create user object_ownership_u2 for login object_ownership_l2;
go
alter role object_ownership_r1 add member object_ownership_u2;
go
alter role object_ownership_r1 drop member object_ownership_u1;
go
-- Add the computed column
alter table object_ownership_s3.old_t add c as (a + b);
go
-- Add the identity column
alter table object_ownership_s3.old_t add id int identity(1,1);
go
use master;
go

-- tsql user=object_ownership_l2 password=123
use object_ownership_db;
go
select current_user;
go

/*** USER MAY NOT HAVE ACCESS TO THESE OBJECTS ***/
/*** SCHEMA OWNER AND OBJECT OWNERS ARE DIFFERENT ***/
/*** SCHEMA OWNED BY ROLE, OBJECTS OWNED BY USER ***/
select * from object_ownership_s3.old_t;
go
select * from object_ownership_s3.old_v;
go
exec object_ownership_s3.old_p;
go
select object_ownership_s3.old_f();
go
insert into object_ownership_s3.old_t values (2, 3);
go
select next value for object_ownership_s3.old_sq;
go
select * from object_ownership_s3.old_tvf();
go
select * from object_ownership_s3.old_mtvf();
go
use master
go

-- tsql user=object_ownership_l1 password=123
use object_ownership_db;
go
select current_user;
go

/*** USER MAY NOT HAVE ACCESS TO THESE OBJECTS ***/
/*** SCHEMA OWNER AND OBJECT OWNERS ARE DIFFERENT ***/
/*** SCHEMA OWNED BY USER, OBJECTS OWNED BY DBO ***/
select * from object_ownership_s2.old_t;
go
select * from object_ownership_s2.old_v;
go
exec object_ownership_s2.old_p;
go
select object_ownership_s2.old_f();
go
insert into object_ownership_s2.old_t values (2, 3);
go
select next value for object_ownership_s2.old_sq;
go
select * from object_ownership_s2.pt2;
go

/*** USER WILL HAVE ACCESS TO THESE OBJECTS ***/
/*** SCHEMA OWNED BY ROLE, OBJECTS OWNED BY CURRENT_USER ***/
select * from object_ownership_s3.old_t1;
go
select * from object_ownership_s3.old_v1;
go
exec object_ownership_s3.old_p1;
go
select object_ownership_s3.old_f1();
go
insert into object_ownership_s3.old_t1 values (2, 3);
go
select next value for object_ownership_s3.old_sq1;
go
use master
go

