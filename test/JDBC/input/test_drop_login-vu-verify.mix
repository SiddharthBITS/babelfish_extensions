-- tsql
-- reset login password
ALTER LOGIN babel_5127_test_sysadmin WITH PASSWORD = 'abc';
GO

ALTER LOGIN babel_5127_test_securityadmin WITH PASSWORD = 'abc';
GO

ALTER LOGIN babel_5127_test_regularuser WITH PASSWORD = 'abc';
GO

-- 1. Test with master user, should still fail
DROP LOGIN [public];
GO

DROP USER [public];
GO

DROP ROLE [public];
GO

-- tsql user=babel_5127_test_sysadmin password=abc
-- 2. Test with sysadmin (should fail again, but due to inability to drop 'public', not privileges)
DROP LOGIN [public];
GO

DROP USER [public];
GO

DROP ROLE [public];
GO

-- tsql user=babel_5127_test_securityadmin password=abc
-- 3. Test with securityadmin, should fail again
DROP LOGIN [public];
GO

DROP USER [public];
GO

DROP ROLE [public];
GO

-- tsql user=babel_5127_test_regularuser password=abc
-- 4. Test with regular user, should fail again
DROP LOGIN [public];
GO

DROP USER [public];
GO

DROP ROLE [public];
GO

-- psql
-- Need to terminate active session before cleaning up the login
SELECT pg_terminate_backend(pid) FROM pg_stat_get_activity(NULL)
WHERE sys.suser_name(usesysid) IN ('babel_5127_test_sysadmin', 'babel_5127_test_securityadmin', 'babel_5127_test_regularuser') AND backend_type = 'client backend' AND usesysid IS NOT NULL;
GO

-- Wait to sync with another session
SELECT pg_sleep(1);
GO