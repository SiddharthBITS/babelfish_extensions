-- tsql
CREATE LOGIN sys_server_permissions_vu_login1 with password = '123'
GO

CREATE LOGIN sys_server_permissions_vu_login2 with password = '123'
GO

CREATE LOGIN sys_server_permissions_vu_login3 with password = '123'
GO

CREATE LOGIN [ad\server_perm_login] from windows;
GO

CREATE VIEW sys_server_permissions_vu_prepare_view AS
    SELECT pr.name, pr.type_desc,   
        pe.state_desc, pe.permission_name, pe.class_desc   
    FROM sys.server_principals AS pr   
    JOIN sys.server_permissions AS pe   
        ON pe.grantee_principal_id = pr.principal_id 
    WHERE pr.name like 'sys_server_permissions_vu_login%' OR pr.name IN ('jdbc_user','ad\server_perm_login','public')
    order by pr.name;
GO

GRANT SELECT ON dbo.sys_server_permissions_vu_prepare_view TO PUBLIC;
GO