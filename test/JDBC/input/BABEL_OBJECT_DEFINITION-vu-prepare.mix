-- Test OBJECT_DEFINITION with objects having definitions larger than 4000 characters
-- Create a stored procedure with a large definition
CREATE PROCEDURE dbo.object_definition_Largeproc
AS
BEGIN
    -- Create a massive procedure with over 10,000 characters
    DECLARE @i INT = 1;
    DECLARE @result NVARCHAR(MAX) = '';
    
    -- Generate a large amount of code to exceed 8000 characters
    WHILE @i <= 1000
    BEGIN
        SET @result = @result + 'SELECT ''This is line ' + CAST(@i AS NVARCHAR(10)) + ' of the stored procedure with an extremely long string to help reach well beyond the 8000 character limit. We need to make sure this exceeds the traditional varchar limits by a significant margin. Adding more text to ensure we go well beyond the 8000 character threshold for testing OBJECT_DEFINITION with large objects. This should create a sufficiently large definition to test edge cases and ensure proper handling of large object definitions in Babelfish. Adding even more text to make this line extremely long so that we can reach our character count target with fewer iterations. The quick brown fox jumps over the lazy dog. The five boxing wizards jump quickly. How vexingly quick daft zebras jump! Pack my box with five dozen liquor jugs. Amazingly few discotheques provide jukeboxes. Crazy Fredrick bought many very exquisite opal jewels. The job requires extra pluck and zeal from every young wage earner.'' AS Line' + CAST(@i AS NVARCHAR(10)) + ';' + CHAR(13) + CHAR(10);
        SET @i = @i + 1;
    END
    
