-- Display results
SELECT 
    ID,
    Description,
    InputSmallDateTime,
    TimeZone,
    Result,
    CASE 
        WHEN ISDATE(Result) = 1 THEN 'Valid DateTime'
        ELSE 'Invalid/Error'
    END AS ResultStatus
FROM SmallDateTimeZoneTest 
ORDER BY ID;
