-- 3. Function returning SMALLDATETIME
CREATE FUNCTION dbo.GetCurrentSmallDateTime()
RETURNS SMALLDATETIME
AS
BEGIN
    RETURN CAST('2023-06-17 14:30' AS SMALLDATETIME);
END;
GO

