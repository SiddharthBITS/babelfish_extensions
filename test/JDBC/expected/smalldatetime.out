-- Time-based grouping
SELECT 
    DATEPART(HOUR, SmallDateTimeColumn) AS Hour,
    COUNT(*) AS EventCount
FROM SmallDateTimeExpressionTest
GROUP BY DATEPART(HOUR, SmallDateTimeColumn)
ORDER BY Hour;
