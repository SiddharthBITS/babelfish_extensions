    COALESCE(NullableSmallDateTimeColumn, SmallDateTimeColumn, CAST('1900-01-01 00:00' AS SMALLDATETIME)) AS CoalescedSmallDateTime,
    Description
FROM SmallDateTimeExpressionTest ORDER BY SmallDateTimeColumn;
