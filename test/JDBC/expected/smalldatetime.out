-- Rounding to hour (since SMALLDATETIME is already minute-precise)
SELECT 
    SmallDateTimeColumn,
    DATEADD(HOUR, DATEDIFF(HOUR, 0, SmallDateTimeColumn), 0) AS RoundedToHour
FROM SmallDateTimeExpressionTest ORDER BY SmallDateTimeColumn;
GO
