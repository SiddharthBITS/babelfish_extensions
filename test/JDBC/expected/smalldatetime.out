-- Implicit conversion
-- Create a function that takes a SMALLDATETIME parameter
CREATE FUNCTION dbo.TestSmallDateTimeFunction(@SmallDateTimeParam SMALLDATETIME)
RETURNS SMALLDATETIME
AS
BEGIN
    RETURN @SmallDateTimeParam;
END
GO

