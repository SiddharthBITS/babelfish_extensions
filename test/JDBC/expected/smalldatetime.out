-- 6. Index testing:
-- Create test table with SMALLDATETIME
CREATE TABLE SmallDateTimeIndexTest (
    ID INT IDENTITY PRIMARY KEY,
    SmallDateTimeColumn SMALLDATETIME,
    SmallDateTimeColumn2 SMALLDATETIME,
    Description NVARCHAR(100),
    NumericColumn INT
);
GO

