-- Test DATE_BUCKET function
DECLARE @sdt SMALLDATETIME = '2023-06-15 14:30';
SELECT 
    DATE_BUCKET(WEEK, 1, @sdt) AS WeekBucket,
    DATE_BUCKET(MONTH, 1, @sdt) AS MonthBucket,
    DATE_BUCKET(YEAR, 1, @sdt) AS YearBucket;
GO
