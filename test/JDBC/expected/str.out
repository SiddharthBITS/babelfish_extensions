-- 8. Edge Case Tests
SELECT
    -- Minimum and maximum values
    STR(-1e308, 20, 2) AS MinFloatTest,
    STR(1e308, 20, 2) AS MaxFloatTest,
    
    -- Precision tests
    STR(0.00000000001, 15, 12) AS SmallPrecisionTest,
    STR(123456789.987654321, 20, 9) AS LargePrecisionTest,
    
    -- Zero variants
    STR(0.0, 10, 2) AS ZeroDecimalTest,
    STR(-0.0, 10, 2) AS NegativeZeroTest,
    STR(0.000000001, 15, 10) AS SmallZeroTest;
GO
