-- =============================================
-- DEPENDENT OBJECTS - VIEWS
-- =============================================
-- 13. Create Views
CREATE VIEW str_v1 AS
SELECT 
    ID,
    NumberValue,
    Length,
    Decimal,
    STR(NumberValue, Length, Decimal) AS FormattedValue,
    ExpectedOutput,
    CASE 
        WHEN STR(NumberValue, Length, Decimal) = ExpectedOutput THEN 'Pass'
        ELSE 'Fail'
    END AS TestResult
FROM str_t1;
GO

CREATE VIEW str_v2 AS
SELECT 
    ID,
    NumberValue,
    Length,
    Decimal,
    STR(NumberValue, Length, Decimal) AS FormattedValue,
    ExpectedOutput,
    CASE 
        WHEN STR(NumberValue, Length, Decimal) = ExpectedOutput THEN 'Pass'
        ELSE 'Fail'
    END AS TestResult
FROM str_t2;
GO

-- Test Views
SELECT * FROM str_v1 WHERE TestResult = 'Fail';
SELECT * FROM str_v2 WHERE TestResult = 'Fail';
GO
