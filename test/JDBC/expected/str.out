CREATE TYPE str_type_decimal FROM DECIMAL(18,6);
CREATE TYPE str_type_float FROM FLOAT;
GO

-- Create base tables
CREATE TABLE str_t1 (
    ID INT IDENTITY(1,1) PRIMARY KEY,
    NumberValue DECIMAL(18,6),
    Length INT,
    Decimal INT,
    ExpectedOutput VARCHAR(100),
    Description VARCHAR(200)
);
GO

CREATE TABLE str_t2 (
    ID INT IDENTITY(1,1) PRIMARY KEY,
    NumberValue FLOAT,
    Length INT,
    Decimal INT,
    ExpectedOutput VARCHAR(100),
    Description VARCHAR(200)
);
GO

