-- =============================================
-- DEPENDENT OBJECTS - COMPUTED COLUMNS
-- =============================================
-- 16. Create Table with Computed Columns
CREATE TABLE str_computed_t1 (
    ID INT IDENTITY(1,1) PRIMARY KEY,
    NumberValue DECIMAL(18,6),
    DefaultFormat AS STR(NumberValue) PERSISTED,
    Format102 AS STR(NumberValue, 10, 2) PERSISTED,
    Format154 AS STR(NumberValue, 15, 4) PERSISTED,
    IsOverflow AS CASE WHEN STR(NumberValue, 5, 2) LIKE '*%' THEN 1 ELSE 0 END PERSISTED
);
GO


