-- =============================================
-- DEPENDENT OBJECTS - FUNCTIONS
-- =============================================
-- 14. Create Functions
CREATE FUNCTION str_fn_formatnumber
(
    @Number DECIMAL(18,6),
    @MinWidth INT,
    @MaxWidth INT,
    @Decimals INT
)
RETURNS VARCHAR(100)
AS
BEGIN
    DECLARE @Result VARCHAR(100);
    DECLARE @CurrentWidth INT = @MinWidth;
    
    WHILE @CurrentWidth <= @MaxWidth
    BEGIN
        SET @Result = STR(@Number, @CurrentWidth, @Decimals);
        IF @Result NOT LIKE '*%'
            BREAK;
        SET @CurrentWidth = @CurrentWidth + 1;
    END
    
    RETURN @Result;
END;
GO

CREATE FUNCTION str_fn_formatcalculation
(
    @Value1 DECIMAL(18,6),
    @Value2 DECIMAL(18,6),
    @Operation CHAR(1)
)
RETURNS TABLE
AS
RETURN
(
    SELECT
        CASE @Operation
            WHEN '+' THEN STR(@Value1 + @Value2, 20, 2)
            WHEN '-' THEN STR(@Value1 - @Value2, 20, 2)
            WHEN '*' THEN STR(@Value1 * @Value2, 20, 2)
            WHEN '/' THEN STR(@Value1 / NULLIF(@Value2, 0), 20, 4)
            ELSE NULL
        END AS Result
);
GO

-- Test Functions
SELECT dbo.str_fn_formatnumber(123.456789, 5, 15, 2);
SELECT * FROM dbo.str_fn_formatcalculation(123.45, 67.89, '+');
GO
