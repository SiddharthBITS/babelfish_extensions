-- 7. Different Numeric Types Tests
SELECT
    -- Integer types
    STR(CAST(123 AS TINYINT), 10, 2) AS TinyIntTest,
    STR(CAST(123 AS SMALLINT), 10, 2) AS SmallIntTest,
    STR(CAST(123 AS INT), 10, 2) AS IntTest,
    STR(CAST(123 AS BIGINT), 10, 2) AS BigIntTest,
    
    -- Decimal types
    STR(CAST(123.456 AS DECIMAL(10,3)), 10, 2) AS DecimalTest,
    STR(CAST(123.456 AS NUMERIC(10,3)), 10, 2) AS NumericTest,
    
    -- Money types
    STR(CAST(123.456 AS MONEY), 10, 2) AS MoneyTest,
    STR(CAST(123.456 AS SMALLMONEY), 10, 2) AS SmallMoneyTest;
GO
