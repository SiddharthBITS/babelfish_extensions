-- =============================================
-- BASIC FUNCTIONAL TESTS
-- =============================================
-- 1. Basic STR Tests
SELECT 
    STR(123.456) AS DefaultParams,
    STR(123.456, 10, 2) AS SpecifiedParams,
    STR(-123.456, 10, 2) AS NegativeNumber,
    STR(0, 5, 2) AS ZeroValue;
GO
~~START~~
varchar#!#varchar#!#varchar#!#varchar
       123#!#    123.46#!#   -123.46#!# 0.00
~~END~~


-- 2. Length Parameter Tests
SELECT
    STR(123.456, 3, 0) AS TooShort,           -- Returns '***'
    STR(123.456, 6, 0) AS ExactLength,        -- Returns ' 123'
    STR(123.456, 10, 0) AS ExtraSpace,        -- Returns '       123'
    STR(9999.99, 5, 0) AS LengthOverflow;     -- Returns '*****'
GO
~~START~~
varchar#!#varchar#!#varchar#!#varchar
123#!#   123#!#       123#!#10000
~~END~~


-- 3. Decimal Parameter Tests
SELECT
    STR(123.456789, 10, 0) AS NoDecimals,     -- Returns '       123'
    STR(123.456789, 10, 2) AS TwoDecimals,    -- Returns '    123.46'
    STR(123.456789, 10, 4) AS FourDecimals,   -- Returns '  123.4568'
    STR(123.456789, 10, 6) AS SixDecimals;    -- Returns '123.456789'
GO
~~START~~
varchar#!#varchar#!#varchar#!#varchar
       123#!#    123.46#!#  123.4568#!#123.456789
~~END~~


-- 4. Rounding Tests
SELECT
    STR(123.454, 10, 2) AS RoundDown,         -- Returns '    123.45'
    STR(123.455, 10, 2) AS RoundUp,           -- Returns '    123.46'
    STR(123.45, 10, 2) AS NoRounding,         -- Returns '    123.45'
    STR(9.999, 10, 2) AS RoundToNextInteger;  -- Returns '     10.00'
GO
~~START~~
varchar#!#varchar#!#varchar#!#varchar
    123.45#!#    123.46#!#    123.45#!#     10.00
~~END~~


-- 5. Scientific Notation Tests
SELECT
    STR(1.23456E2, 10, 2) AS PositiveExponent,    -- 123.46
    STR(1.23456E-2, 10, 4) AS NegativeExponent,   -- 0.0123
    STR(1E10, 15, 2) AS LargeExponent,
    STR(1E-10, 15, 12) AS SmallExponent;
GO
