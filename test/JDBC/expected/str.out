-- =============================================
-- DEPENDENT OBJECTS - STORED PROCEDURES
-- =============================================
-- 15. Create Procedures
CREATE PROCEDURE str_sp_formatnumber
    @Number DECIMAL(18,6),
    @MinDecimals INT = 0,
    @MaxDecimals INT = 6
AS
BEGIN
    DECLARE @CurrentDecimals INT = @MinDecimals;
    
    WHILE @CurrentDecimals <= @MaxDecimals
    BEGIN
        SELECT 
            @CurrentDecimals AS Decimals,
            STR(@Number, 20, @CurrentDecimals) AS FormattedValue;
        
        SET @CurrentDecimals = @CurrentDecimals + 1;
    END
END;
GO

CREATE PROCEDURE str_sp_compareformats
    @Number DECIMAL(18,6)
AS
BEGIN
    SELECT 
        'Default' AS Format,
        STR(@Number) AS Result
    UNION ALL
    SELECT 
        '10,2',
        STR(@Number, 10, 2)
    UNION ALL
    SELECT
        '15,4',
        STR(@Number, 15, 4)
    UNION ALL
    SELECT
        '20,6',
        STR(@Number, 20, 6)
    ORDER BY Format;
END;
GO

-- Test Procedures
EXEC str_sp_formatnumber 123.456789, 0, 4;
EXEC str_sp_compareformats 123.456789;
GO
