    STR(CAST('Infinity' AS FLOAT), 10, 2) AS InfinityTest,
    STR(CAST('-Infinity' AS FLOAT), 10, 2) AS NegativeInfinityTest,
    STR(CAST('NaN' AS FLOAT), 10, 2) AS NaNTest;
