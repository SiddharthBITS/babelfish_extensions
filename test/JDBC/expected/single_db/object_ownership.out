-- tsql
/** CREATE DATABASE **/
create database object_ownership_db;
go
use object_ownership_db;
go

/** CREATE LOGIN, USER AND ROLE **/
create login object_ownership_l1 with password = '123';
go
create user object_ownership_u1 for login object_ownership_l1;
go
create role object_ownership_r1;
go
alter role object_ownership_r1 add member object_ownership_u1;
go
create login object_ownership_l3 with password = '123';
go
create user object_ownership_u3 for login object_ownership_l3;
go
create login object_ownership_l4 with password = '123';
go

/** CREATE SCHEMAS WITH DIFFERENT OWNERS **/
create schema object_ownership_s1;
go
create schema object_ownership_s2 authorization object_ownership_u1;
go
create schema object_ownership_s3 authorization object_ownership_r1;
go

/** CREATE OBJECTS IN DIFFERENT SCHEMAS USING DBO **/
/** SCHEMA OWNER AND CURRENT USER ARE SAME **/
create table object_ownership_s1.t(a int, b int);
go
create view object_ownership_s1.v as select 1;
go
create proc object_ownership_s1.p as select 2;
go
create function object_ownership_s1.f() returns int begin declare @a int; set @a = 1; return @a; END
go
create sequence object_ownership_s1.sq start with 1 increment by 1 ;
go

/** CREATE PARTITION FUNCTION AND SCHEME **/
create partition function pf2 (datetime)
as range right for values 
(
    '2023-01-01', 
    '2024-01-01',
    '2025-01-01'
);
go

create partition scheme ps2
as partition pf2 
all to ([primary]);
go

/** CREATE OBJECTS IN GUEST SCHEMA USING DBO USER **/
create table guest.t(a int, b int);
go
create view guest.v as select 1;
go
create proc guest.p as select 2;
go
create function guest.f() returns int begin declare @a int; set @a = 1; return @a; END
go
create sequence guest.sq start with 1 increment by 1 ;
go
grant connect to guest;
go

/** SCHEMA OWNER IS ROLE, CURRENT USER IS DBO **/
create table object_ownership_s3.t(a int, b int);
go
create view object_ownership_s3.v as select 1;
go
create proc object_ownership_s3.p as select 2;
go
create function object_ownership_s3.f() returns int begin declare @a int; set @a = 1; return @a; END
go
create sequence object_ownership_s3.sq start with 1 increment by 1 ;
go
create index idx on object_ownership_s3.t(a);
go
create trigger object_ownership_s3.tr on object_ownership_s3.t after insert as select 1;
go
create function object_ownership_s3.tvf() returns table as return (select '1' as col);
go
create function object_ownership_s3.mtvf()
returns @result table([Id] int) AS
begin
    insert into @result values (1) return 
end
go
create type object_ownership_s3.type from sys.varchar(10)
go
create type object_ownership_s3.ttype as table (id int)
go
use master
go

-- tsql user=object_ownership_l1 password=123
use object_ownership_db;
go
select current_user
go
~~START~~
varchar
object_ownership_u1
~~END~~


/** CURRENT USER CAN CREATE OBJECT IN THESE SCHEMAS **/
/** SCHEMA OWNER AND CURRENT USER ARE SAME **/
create table object_ownership_s2.t1(a int, b int);
go
create view object_ownership_s2.v1 as select 1;
go
create proc object_ownership_s2.p1 as select 2;
go
create function object_ownership_s2.f1() returns int begin declare @a int; set @a = 1; return @a; END
go
create sequence object_ownership_s2.sq1 start with 1 increment by 1 ;
go
create index idx1 on object_ownership_s2.t1(a);
go
create trigger object_ownership_s2.tr1 on object_ownership_s2.t1 after insert as select 1;
go
create function object_ownership_s2.tvf1() returns table as return (select '1' as col);
go
create function object_ownership_s2.mtvf1()
returns @result table([Id] int) AS
begin
    insert into @result values (1) return 
end
go
create type object_ownership_s2.type1 from sys.varchar(10)
go
create type object_ownership_s2.ttype1 as table (id int)
go

/** SCHEMA OWNER IS A ROLE AND CURRENT USER IS MEMBER OF THAT ROLE **/
create table object_ownership_s3.t1(a int, b int);
go
create view object_ownership_s3.v1 as select 1;
go
create proc object_ownership_s3.p1 as select 2;
go
create function object_ownership_s3.f1() returns int begin declare @a int; set @a = 1; return @a; END
go
create sequence object_ownership_s3.sq1 start with 1 increment by 1 ;
go
create index idx1 on object_ownership_s3.t1(a);
go
create trigger object_ownership_s3.tr1 on object_ownership_s3.t1 after insert as select 1;
go
create function object_ownership_s3.tvf1() returns table as return (select '1' as col);
go
create function object_ownership_s3.mtvf1()
returns @result table([Id] int) AS
begin
    insert into @result values (1) return 
end
go
create type object_ownership_s3.type1 from sys.varchar(10)
go
create type object_ownership_s3.ttype1 as table (id int)
go
use master
go

-- tsql
create login object_ownership_l2 with password = '123'
go
use object_ownership_db;
go
create user object_ownership_u2 for login object_ownership_l2;
go
alter role object_ownership_r1 add member object_ownership_u2;
go
grant SELECT, INSERT, UPDATE, DELETE, EXECUTE on schema::object_ownership_s3 to object_ownership_u3;
go
use master;
go

-- tsql user=object_ownership_l2 password=123
use object_ownership_db;
go
select current_user;
go
~~START~~
varchar
object_ownership_u2
~~END~~


/** USER SHOULD CREATE OBJECTS IN THIS SCHEMA **/
/** SCHEMA OWNER IS A ROLE AND CURRENT USER IS MEMBER OF THAT ROLE **/
create table object_ownership_s3.t2(a int, b int);
go
create view object_ownership_s3.v2 as select 1;
go
create proc object_ownership_s3.p2 as select 2;
go
create function object_ownership_s3.f2() returns int begin declare @a int; set @a = 1; return @a; END
go
create index idx1 on object_ownership_s3.t2(a);
go
create trigger object_ownership_s3.tr2 on object_ownership_s3.t2 after insert as select 1;
go
create function object_ownership_s3.tvf2() returns table as return (select '1' as col);
go
create function object_ownership_s3.mtvf2()
returns @result table([Id] int) AS
begin
    insert into @result values (1) return 
end
go
create type object_ownership_s3.type2 from sys.varchar(10)
go
create type object_ownership_s3.ttype2 as table (id int)
go

/***** SHOULD BE ABLE TO CREATE PARTITION TABLES **********/
create table object_ownership_s3.pt2
(
    saleid int identity(1,1),
    saledate datetime,
    amount decimal(10,2),
    customerid int,
    productid int
) on ps2(saledate);  -- specify the partitioning column
go

