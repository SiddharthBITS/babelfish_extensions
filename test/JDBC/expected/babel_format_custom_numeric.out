-- Setup: Create a table with various numeric types
CREATE TABLE format_numeric_test (
    int_val INT,
    bigint_val BIGINT,
    smallint_val SMALLINT,
    tinyint_val TINYINT,
    decimal_val DECIMAL(18,9),
    numeric_val NUMERIC(18,9),
    money_val MONEY,
    smallmoney_val SMALLMONEY,
    float_val FLOAT,
    real_val REAL
);
GO

-- Insert test data
INSERT INTO format_numeric_test VALUES
(1234567, 1234567890123456, 12345, 123, 1234567.123456789, 9876543.987654321, 1234.56, 123.45, 1234567.89, 123456.7);
GO
~~ROW COUNT: 1~~


-- 1. Basic integer formatting
SELECT
    FORMAT(int_val, '00000000') AS int_leading_zeros,
    FORMAT(int_val, '########') AS int_no_leading_zeros,
    FORMAT(int_val, '#,###') AS int_with_commas,
    FORMAT(bigint_val, '#,###') AS bigint_with_commas,
    FORMAT(smallint_val, '000000') AS smallint_leading_zeros,
    FORMAT(tinyint_val, '000') AS tinyint_leading_zeros
FROM format_numeric_test;
GO
~~START~~
nvarchar#!#nvarchar#!#nvarchar#!#nvarchar#!#nvarchar#!#nvarchar
~~ERROR (Code: 33557097)~~

~~ERROR (Message: 00000000 is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 2. Decimal place formatting
SELECT
    FORMAT(decimal_val, '0.00') AS two_decimal_places,
    FORMAT(decimal_val, '0.000000000') AS nine_decimal_places,
    FORMAT(decimal_val, '#.##########') AS max_decimal_places,
    FORMAT(numeric_val, '0.000') AS numeric_three_places,
    FORMAT(float_val, '0.##') AS float_two_places,
    FORMAT(real_val, '0.###') AS real_three_places
FROM format_numeric_test;
GO
~~START~~
nvarchar#!#nvarchar#!#nvarchar#!#nvarchar#!#nvarchar#!#nvarchar
~~ERROR (Code: 33557097)~~

~~ERROR (Message: 0.00 is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 3. Combination of integer and decimal formatting
SELECT
    FORMAT(decimal_val, '#,##0.00') AS comma_two_decimals,
    FORMAT(numeric_val, '#,##0.000') AS comma_three_decimals,
    FORMAT(money_val, '#,##0.00') AS money_standard_format,
    FORMAT(smallmoney_val, '#,##0.00') AS smallmoney_standard_format
FROM format_numeric_test;
GO
~~START~~
nvarchar#!#nvarchar#!#nvarchar#!#nvarchar
~~ERROR (Code: 33557097)~~

~~ERROR (Message: #,##0.00 is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 4. Percentage formatting
SELECT
    FORMAT(decimal_val / 100, '0.00%') AS decimal_percent,
    FORMAT(float_val / 100, '0.00%') AS float_percent,
    FORMAT(0.1234, '0.00%') AS small_value_percent,
    FORMAT(1.2345, '0.00%') AS large_value_percent
FROM format_numeric_test;
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: 0.00% is not supported/invalid format when converting from NUMERIC to a character string.)~~



