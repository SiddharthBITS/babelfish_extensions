-- 6. Scientific notation
SELECT
    FORMAT(bigint_val, '0.00E+0') AS bigint_scientific,
    FORMAT(decimal_val, '0.00E+0') AS decimal_scientific,
    FORMAT(float_val, '0.00E+0') AS float_scientific,
    FORMAT(0.00000123, '0.00E+0') AS small_value_scientific,
    FORMAT(123000000, '0.00E+0') AS large_value_scientific
FROM format_numeric_test;
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: 0.00E+0 is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 7. Custom thousand separators
SELECT
    FORMAT(int_val, '#,###', 'en-US') AS us_thousand_sep,
    FORMAT(int_val, '#,###', 'de-DE') AS german_thousand_sep,
    FORMAT(int_val, '#,###', 'fr-FR') AS french_thousand_sep
FROM format_numeric_test;
GO
~~START~~
nvarchar#!#nvarchar#!#nvarchar
~~ERROR (Code: 33557097)~~

~~ERROR (Message: #,### is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 8. Padding with spaces
SELECT
    FORMAT(int_val, '00000000') AS zero_padded,
    FORMAT(int_val, '        0') AS space_padded_right,
    FORMAT(int_val, '0        ') AS space_padded_left
FROM format_numeric_test;
GO
~~START~~
nvarchar#!#nvarchar#!#nvarchar
~~ERROR (Code: 33557097)~~

~~ERROR (Message: 00000000 is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 9. Negative number formatting
SELECT
    FORMAT(-decimal_val, '#,##0.00;(#,##0.00)') AS negative_with_parentheses,
    FORMAT(-decimal_val, '#,##0.00;-#,##0.00') AS negative_with_minus,
    FORMAT(-money_val, 'C') AS negative_currency
FROM format_numeric_test;
GO
~~START~~
nvarchar#!#nvarchar#!#nvarchar
~~ERROR (Code: 33557097)~~

~~ERROR (Message: #,##0.00;(#,##0.00) is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 10. Rounding behavior
SELECT
    FORMAT(1234.5678, '0.00') AS rounded_two_places,
    FORMAT(1234.5678, '0.000') AS rounded_three_places,
    FORMAT(1234.5678, '0') AS rounded_to_integer
FROM format_numeric_test;
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: 0.00 is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 11. Truncation behavior
SELECT
    FORMAT(1234.5678, '#.##') AS truncated_two_places,
    FORMAT(1234.5678, '#.###') AS truncated_three_places,
    FORMAT(1234.5678, '#') AS truncated_to_integer
FROM format_numeric_test;
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: #.## is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 12. Zero value handling
SELECT
    FORMAT(0, '#.##') AS zero_with_hash,
    FORMAT(0, '0.00') AS zero_with_zeros,
    FORMAT(0, '#,##0.00') AS zero_with_group_separator
FROM format_numeric_test;
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: #.## is not supported/invalid format when converting from NUMERIC to a character string.)~~



-- 13. Very large and very small numbers
DECLARE @very_large DECIMAL(38,0) = 1234567890123456789012345678901234567;
DECLARE @very_small DECIMAL(38,37) = 0.0000000000000000000000000000000000001;
SELECT
    FORMAT(@very_large, '#,###') AS large_number_formatted,
    FORMAT(@very_small, '0.0000000000000000000000000000000000000') AS small_number_formatted;
GO
~~START~~
nvarchar#!#nvarchar
~~ERROR (Code: 33557097)~~

~~ERROR (Message: #,### is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 14. Custom format with text
SELECT
    FORMAT(int_val, '"Total: "$#,##0') AS custom_with_prefix,
    FORMAT(decimal_val, '#,##0.00" units"') AS custom_with_suffix,
    FORMAT(money_val, '$#,##0.00 "USD"') AS custom_currency_format
FROM format_numeric_test;
GO
~~START~~
nvarchar#!#nvarchar#!#nvarchar
~~ERROR (Code: 33557097)~~

~~ERROR (Message: "Total: "$#,##0 is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 15. Hexadecimal format (for integers)
SELECT
    FORMAT(int_val, 'X') AS hex_uppercase,
    FORMAT(int_val, 'x') AS hex_lowercase,
    FORMAT(bigint_val, 'X') AS bigint_hex
FROM format_numeric_test;
GO
