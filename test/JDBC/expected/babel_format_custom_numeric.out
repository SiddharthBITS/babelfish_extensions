-- 17. Combinations of # and 0
SELECT
    FORMAT(1234.5678, '#,##0.0#') AS mixed_format1,
    FORMAT(1234.5678, '#,###.#0#') AS mixed_format2,
    FORMAT(0.1234, '#,##0.0#') AS mixed_format_small_number
FROM format_numeric_test;
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: #,##0.0# is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 18. Escaping special characters
SELECT
    FORMAT(1234.56, '\#\#\#\#,##0.00') AS escaped_hash,
    FORMAT(1234.56, '"\#\#"#,##0.00') AS quoted_hash
FROM format_numeric_test;
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: \#\#\#\#,##0.00 is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 19. Edge cases
SELECT
    FORMAT(CAST(0 AS MONEY), 'C') AS zero_money,
    FORMAT(CAST(-0 AS DECIMAL(18,2)), '#,##0.00;(#,##0.00)') AS negative_zero,
    FORMAT(1 / 3, '0.############') AS repeating_decimal,
    FORMAT(CAST('1E+40' AS FLOAT), '0.0000E+0') AS very_large_float
FROM format_numeric_test;
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: #,##0.00;(#,##0.00) is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- 20. Format with percentage and scaling
SELECT
    FORMAT(0.1234, 'P') AS default_percent,
    FORMAT(0.1234, 'P1') AS one_decimal_percent,
    FORMAT(0.1234, '#,##0.00%') AS custom_percent,
    FORMAT(1234, '#,##0.00%') AS scaled_up_percent
FROM format_numeric_test;
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: #,##0.00% is not supported/invalid format when converting from NUMERIC to a character string.)~~


-- Cleanup
DROP TABLE format_numeric_test;
GO
