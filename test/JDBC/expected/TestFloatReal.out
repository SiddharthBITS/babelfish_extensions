3#!#0#!#-1.0 < x <= 0.0#!#-0.75#!#-1.23E-4#!#4
4#!#0#!#0.0 < x <= 1.0#!#1.23E-4#!#0.75#!#4
5#!#0#!#1.0 < x <= 1000.0#!#2.5#!#750.0#!#3
