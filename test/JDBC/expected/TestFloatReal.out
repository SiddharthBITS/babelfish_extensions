-- Test cascading updates (adding CASCADE option)
CREATE TABLE float_real_order_details_cascade (
    order_id INT,
    product_id INT,
    quantity INT,
    unit_price FLOAT,
    weight_kg REAL,
    CONSTRAINT fk_product_cascade FOREIGN KEY (product_id) 
        REFERENCES float_real_master_products(product_id)
        ON UPDATE CASCADE
        ON DELETE CASCADE
);
GO

