-- Create a function that takes a DATETIME2 parameter
CREATE FUNCTION dbo.TestDateTime2Function(@DateTime2Param DATETIME2)
RETURNS DATETIME2
AS
BEGIN
    RETURN @DateTime2Param;
END
GO

