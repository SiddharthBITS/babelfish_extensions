-- UNIONS
SELECT DateTime2Column 
FROM DateTime2ExpressionTest 
WHERE DATEPART(HOUR, DateTime2Column) < 12
UNION
SELECT DateTime2Column 
FROM DateTime2ExpressionTest 
WHERE DATEPART(HOUR, DateTime2Column) > 20
ORDER BY DateTime2Column;
