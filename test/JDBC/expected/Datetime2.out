~~END~~


-- Create an index with included columns
CREATE INDEX IX_DateTime2IndexTest_DateTime2Column_Include 
ON DateTime2IndexTest(DateTime2Column)
INCLUDE (Description, NumericColumn);
GO

-- Test index with included columns
