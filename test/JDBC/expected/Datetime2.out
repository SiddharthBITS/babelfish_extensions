UPDATE DateTime2DMLTest
SET SimpleDateTime = DATEADD(hour, 1, SimpleDateTime)
WHERE ID = 3;
GO
~~ROW COUNT: 1~~


-- Mass update
UPDATE DateTime2DMLTest
SET Description = 'Mass updated';
GO
~~ROW COUNT: 7~~


-- Conditional update
UPDATE DateTime2DMLTest
SET SimpleDateTime = '2023-06-16 09:00:00'
WHERE SimpleDateTime < '2023-06-16 12:00:00';
GO

