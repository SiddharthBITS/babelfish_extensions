-- modulo operator between MONEY/SMALLMONEY and DECIMAL
-- use the postgres internal numeric_mod
SELECT CAST(922337203685477.5807 AS MONEY) % CAST(2833.292334 AS NUMERIC(12, 7));
GO
~~START~~
numeric
2144.3324440
~~END~~

