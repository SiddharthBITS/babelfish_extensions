SELECT a, a % 1 AS MOD_INT, a % CAST(1 AS MONEY) AS MOD_MONEY, a % CAST(1 AS DECIMAL(10, 5)) AS MOD_DECIMAL FROM fixeddecimal_modulo_t1;
GO
~~START~~
money#!#money#!#money#!#numeric
