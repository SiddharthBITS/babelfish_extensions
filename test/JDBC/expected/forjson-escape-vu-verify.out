    SELECT JSON_QUERY(EmployeeDetails, '$.skills') as test_union FROM babel_5112_test7
    UNION
    SELECT JSON_QUERY(EmployeeDetails, '$.contact') as test_union FROM babel_5112_test7
) as union_query
order by test_union
FOR JSON PATH;
go
