---------------------------------------------      Test 4  - where clause   -------- -------------------------------------------------
SELECT  ID, EmployeeDetails as non_json_query_col , JSON_QUERY(EmpID) as json_query_col FROM babel_5112_test4
WHERE JSON_QUERY(EmployeeDetails, '$.skills')  = '["C++"]'  
for json path;
go
~~START~~
nvarchar
[{"ID": 2, "non_json_query_col": "{\"skills\": [\"C++\"] , \"contact\": {\"email\": \"sasuke@example.com\", \"phone\": \"923-456-777\"}}", "json_query_col": {"age": 19, "name": "Sasuke"}}]
~~END~~


SELECT  ID, EmployeeDetails as non_json_query_col , JSON_QUERY(EmpID) as json_query_col FROM babel_5112_test4
WHERE JSON_QUERY(EmployeeDetails, '$.skills')  = '["C++"]'  
for json auto, without_array_wrapper;
go
~~START~~
nvarchar
{"ID": 2, "non_json_query_col": "{\"skills\": [\"C++\"] , \"contact\": {\"email\": \"sasuke@example.com\", \"phone\": \"923-456-777\"}}", "json_query_col": {"age": 19, "name": "Sasuke"}}
~~END~~



---------------------------------------------      Test 5  - Subquery check    -------------------------------------------------
SELECT ID, child.child_col as json_query_parent_col 
from 
  (select ID ,JSON_QUERY(EmployeeDetails,'$.contact') as child_col from babel_5112_test5 ) child
FOR JSON PATH;
go
~~START~~
nvarchar
[{"ID": 1, "json_query_parent_col": {"email": "naruto@example.com", "phone": "123-456-7890"}}, {"ID": 2, "json_query_parent_col": {"email": "sasuke@example.com", "phone": "923-456-777"}}]
~~END~~


SELECT 
    ID, 
    (SELECT JSON_QUERY(EmployeeDetails, '$.contact') as child_col FROM babel_5112_test5 e1 WHERE e1.id = e2.id) as parent_json_query_col
FROM 
    babel_5112_test5 e2
FOR JSON PATH;
go
~~START~~
nvarchar
[{"ID": 1, "parent_json_query_col": {"email": "naruto@example.com", "phone": "123-456-7890"}}, {"ID": 2, "parent_json_query_col": {"email": "sasuke@example.com", "phone": "923-456-777"}}]
~~END~~


