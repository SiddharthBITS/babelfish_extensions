INSERT INTO GEOSPATIALPOINTGEOGR_dt (location) VALUES ( geography::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 0) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Invalid SRID)~~

INSERT INTO GEOSPATIALPOINTGEOGR_dt (location) VALUES ( geography::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 3452) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Invalid SRID)~~

INSERT INTO GEOSPATIALPOINTGEOGR_dt (location) VALUES ( geography::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 1000) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Invalid SRID)~~


# Negative Test for STGeomFromText for Geography when Lat > 90 or < -90
INSERT INTO GEOSPATIALPOINTGEOGR_dt (location) VALUES ( geography::STGeomFromText('Point(47.65100 -122.34900 32.546000  54.56300)', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Latitude values must be between -90 and 90 degrees)~~

INSERT INTO GEOSPATIALPOINTGEOGR_dt (location) VALUES ( geography::STGeomFromText('Point(47.65100 92.34900 32.546000  54.56300)', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Latitude values must be between -90 and 90 degrees)~~


# Negative Test for STGeomFromText when cast is not provided
INSERT INTO GEOSPATIALPOINTGEOGR_dt (location) VALUES ( STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: function stgeomfromtext(unknown, integer) does not exist)~~


# Negative Test for STGeomFromText when incorrect cast is provided
INSERT INTO GEOSPATIALPOINTGEOGR_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: column "location" is of type geography but expression is of type geometry)~~


# Negative Test for STGeomFromText when a coordinate is missing
INSERT INTO GEOSPATIALPOINTGEOGR_dt (location) VALUES ( geography::STGeomFromText('Point(1.0 )', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Invalid geometry)~~


# Negative Test for STGeomFromText when invalid type is provided
INSERT INTO GEOSPATIALPOINTGEOGR_dt (location) VALUES ( geography::STGeomFromText('Pnt', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Invalid geometry)~~



CREATE TABLE GEOSPATIALPOINTGEOGR_sr (location geography)
INSERT INTO GEOSPATIALPOINTGEOGR_sr (location) VALUES ( geography::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 4120) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOGR_sr (location) VALUES ( geography::STGeomFromText('POINT EMPTY', 4120) );
~~ROW COUNT: 1~~


CREATE VIEW DimOfGeography AS SELECT location.STDimension() FROM GEOSPATIALPOINTGEOGR_dt ORDER BY location.Lat;

CREATE VIEW AreaOfGeography AS SELECT location.STArea() FROM GEOSPATIALPOINTGEOGR_dt ORDER BY location.Lat;

CREATE VIEW TextFromGeography AS SELECT location.STAsText() FROM GEOSPATIALPOINTGEOGR_dt ORDER BY location.Lat;

CREATE VIEW BinaryFromGeography AS SELECT location.STAsBinary() FROM GEOSPATIALPOINTGEOGR_dt ORDER BY location.Lat;

CREATE VIEW CoordsFromGeography AS SELECT location.Lat, location.Long FROM GEOSPATIALPOINTGEOGR_dt ORDER BY location.Lat;

CREATE VIEW SridFromGeography AS SELECT location.STSrid FROM GEOSPATIALPOINTGEOGR_dt ORDER BY location.Lat;

CREATE VIEW EmptyGeography AS SELECT location.STIsEmpty() FROM GEOSPATIALPOINTGEOGR_dt ORDER BY location.Lat;

CREATE VIEW ValidGeography AS SELECT location.STIsValid() FROM GEOSPATIALPOINTGEOGR_dt ORDER BY location.Lat;

CREATE VIEW ClosedGeography AS SELECT location.STIsClosed() FROM GEOSPATIALPOINTGEOGR_dt ORDER BY location.Lat;

CREATE VIEW DisjointTempGeog AS SELECT p1.location.STDisjoint(p2.location) AS disjoints FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_dt p2 ORDER BY p1.location.Lat;

CREATE VIEW DistanceTempGeog AS SELECT p1.location.STDistance(p2.location) AS distance FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_dt p2 ORDER BY p1.location.Lat;

CREATE VIEW IntersectsTempGeog AS SELECT p1.location.STIntersects(p2.location) AS interesecting FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_dt p2 ORDER BY p1.location.Lat;

CREATE VIEW EqualsTempGeog AS SELECT p1.location.STEquals(p2.location) AS equals FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_dt p2 ORDER BY p1.location.Lat;

CREATE VIEW ContainsTempGeog AS SELECT p1.location.STContains(p2.location) AS contain FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_dt p2 ORDER BY p1.location.Lat;

CREATE VIEW equal_opgeog AS SELECT p1.location AS point FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_dt p2 WHERE p1.location = p2.location ORDER BY p1.location.Lat;

CREATE VIEW notequal_opgeog AS SELECT p1.location AS point FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_dt p2 WHERE p1.location <> p2.location ORDER BY p1.location.Lat;


CREATE VIEW DisjointTempGeogsr AS SELECT p1.location.STDisjoint(p2.location) AS disjoints FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_sr p2 ORDER BY p1.location.Lat;

CREATE VIEW DistanceTempGeogsr AS SELECT p1.location.STDistance(p2.location) AS distance FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_sr p2 ORDER BY p1.location.Lat;

CREATE VIEW IntersectsTempGeogsr AS SELECT p1.location.STIntersects(p2.location) AS interesecting FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_sr p2 ORDER BY p1.location.Lat;

CREATE VIEW EqualsTempGeogsr AS SELECT p1.location.STEquals(p2.location) AS equals FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_sr p2 ORDER BY p1.location.Lat;

CREATE VIEW ContainsTempGeogsr AS SELECT p1.location.STContains(p2.location) AS contain FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_sr p2 ORDER BY p1.location.Lat;

CREATE VIEW equal_opgeogsr AS SELECT p1.location AS point FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_sr p2 WHERE p1.location = p2.location ORDER BY p1.location.Lat;

CREATE VIEW notequal_opgeogsr AS SELECT p1.location AS point FROM GEOSPATIALPOINTGEOGR_dt p1 CROSS JOIN GEOSPATIALPOINTGEOGR_sr p2 WHERE p1.location <> p2.location ORDER BY p1.location.Lat;

