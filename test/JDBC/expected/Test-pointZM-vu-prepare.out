CREATE VIEW GeometryHasM AS SELECT location.HasM FROM GEOSPATIALPOINTGEOMRCV_dt ORDER BY location.STX;

CREATE VIEW GeographyHasM AS SELECT location.HasM FROM GEOSPATIALPOINTGEOGRCV_dt ORDER BY location.Lat;
 
CREATE VIEW GeometryHasZ AS SELECT location.HasZ FROM GEOSPATIALPOINTGEOMRCV_dt ORDER BY location.STX;

CREATE VIEW GeographyHasZ AS SELECT location.HasZ FROM GEOSPATIALPOINTGEOGRCV_dt ORDER BY location.Lat;

CREATE VIEW GeometryM AS SELECT location.M FROM GEOSPATIALPOINTGEOMRCV_dt ORDER BY location.STX;

CREATE VIEW GeographyM AS SELECT location.M FROM GEOSPATIALPOINTGEOGRCV_dt ORDER BY location.Lat;

CREATE VIEW GeometryZ AS SELECT location.Z FROM GEOSPATIALPOINTGEOMRCV_dt ORDER BY location.STX;

CREATE VIEW GeographyZ AS SELECT location.Z FROM GEOSPATIALPOINTGEOGRCV_dt ORDER BY location.Lat;

