# This file tests support for POINT with ZM flags
# It also includes test for HasM , HasZ, Z , M functions

# Geometry Test Cases

CREATE TABLE GEOSPATIALPOINTGEOM_dt (location geometry)

# Positive Test for STGeomFromText with SRID 4326

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 )', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 NULL)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 NULL NULL)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 32.546000)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 32.546000 NULL)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900  NULL 32.546000)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('POINT EMPTY', 4326) );
~~ROW COUNT: 1~~


# Positive Test for STPointFromText with SRID 4326

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STPointFromText('Point(47.65100 -22.34900 )', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STPointFromText('Point(47.65100 -22.34900 NULL)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STPointFromText('Point(47.65100 -22.34900 NULL NULL)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STPointFromText('Point(47.65100 -22.34900 32.546000)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STPointFromText('Point(47.65100 -22.34900 32.546000 NULL)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STPointFromText('Point(47.65100 -22.34900  NULL 32.546000)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STPointFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 4326) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STPointFromText('POINT EMPTY', 4326) );
~~ROW COUNT: 1~~


# Positive Test for Point with SRID 4326

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::Point(47.65100, -22.34900, 4326) );
~~ROW COUNT: 1~~


# Negative Test when SRID is not valid
# SRID should be between 0 to 999999
INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)') );
~~ERROR (Code: 8146)~~

~~ERROR (Message: function geometry__stgeomfromtext has no parameters and arguments were supplied.)~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 1000000000 ) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: SRID value should be between 0 and 999999)~~

INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', -1) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: SRID value should be between 0 and 999999)~~


# Negative Test for STGeomFromText when a coordinate is missing
INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Point(1.0 )', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Invalid geometry)~~


# Negative Test for STGeomFromText when invalid type is provided
INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geometry::STGeomFromText('Pnt', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Invalid geometry)~~


# Negative Test for STGeomFromText when cast is not provided
INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: function stgeomfromtext(unknown, integer) does not exist)~~


#  Negative Test for STGeomFromText when Incorrect cast is provided
INSERT INTO GEOSPATIALPOINTGEOM_dt (location) VALUES ( geography::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 4326) );
~~ERROR (Code: 33557097)~~

~~ERROR (Message: column "location" is of type geometry but expression is of type geography)~~



CREATE TABLE GEOSPATIALPOINTGEOM_sr (location geometry)
INSERT INTO GEOSPATIALPOINTGEOM_sr (location) VALUES ( geometry::STGeomFromText('Point(47.65100 -22.34900 32.546000  54.56300)', 4300) );
~~ROW COUNT: 1~~

INSERT INTO GEOSPATIALPOINTGEOM_sr (location) VALUES ( geometry::STGeomFromText('POINT EMPTY', 4300) );
~~ROW COUNT: 1~~


CREATE VIEW DimOfGeometry AS SELECT location.STDimension() FROM GEOSPATIALPOINTGEOM_dt ORDER BY location.STX;

CREATE VIEW AreaOfGeometry AS SELECT location.STArea() FROM GEOSPATIALPOINTGEOM_dt ORDER BY location.STX;

CREATE VIEW TextFromGeometry AS SELECT location.STAsText() FROM GEOSPATIALPOINTGEOM_dt ORDER BY location.STX;

CREATE VIEW BinaryFromGeometry AS SELECT location.STAsBinary() FROM GEOSPATIALPOINTGEOM_dt ORDER BY location.STX;

CREATE VIEW CoordsFromGeometry AS SELECT location.STX, location.STY FROM GEOSPATIALPOINTGEOM_dt ORDER BY location.STX;

CREATE VIEW SridFromGeometry AS SELECT location.STSrid FROM GEOSPATIALPOINTGEOM_dt ORDER BY location.STX;

CREATE VIEW EmptyGeometry AS SELECT location.STIsEmpty() FROM GEOSPATIALPOINTGEOM_dt ORDER BY location.STX;

CREATE VIEW ValidGeometry AS SELECT location.STIsValid() FROM GEOSPATIALPOINTGEOM_dt ORDER BY location.STX;

CREATE VIEW ClosedGeometry AS SELECT location.STIsClosed() FROM GEOSPATIALPOINTGEOM_dt ORDER BY location.STX;

CREATE VIEW DisjointTempGeom AS SELECT p1.location.STDisjoint(p2.location) AS disjoints FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_dt p2 ORDER BY p1.location.STX;

CREATE VIEW DistanceTempGeom AS SELECT p1.location.STDistance(p2.location) AS distance FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_dt p2 ORDER BY p1.location.STX;

CREATE VIEW IntersectsTempGeom AS SELECT p1.location.STIntersects(p2.location) AS interesecting FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_dt p2 ORDER BY p1.location.STX;

CREATE VIEW EqualsTempGeom AS SELECT p1.location.STEquals(p2.location) AS equals FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_dt p2 ORDER BY p1.location.STX;

CREATE VIEW ContainTempGeom AS SELECT p1.location.STContains(p2.location) AS contain FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_dt p2 ORDER BY p1.location.STX;

CREATE VIEW equals_opgeom AS SELECT p1.location AS point FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_dt p2 WHERE p1.location = p2.location ORDER BY p1.location.STX;

CREATE VIEW notequal_opgeom AS SELECT p1.location AS point FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_dt p2 WHERE p1.location <> p2.location ORDER BY p1.location.STX;


CREATE VIEW DisjointTempGeomsr AS SELECT p1.location.STDisjoint(p2.location) AS disjoints FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_sr p2 ORDER BY p1.location.STX;

CREATE VIEW DistanceTempGeomsr AS SELECT p1.location.STDistance(p2.location) AS distance FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_sr p2 ORDER BY p1.location.STX;

CREATE VIEW IntersectsTempGeomsr AS SELECT p1.location.STIntersects(p2.location) AS interesecting FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_sr p2 ORDER BY p1.location.STX;

CREATE VIEW EqualsTempGeomsr AS SELECT p1.location.STEquals(p2.location) AS equals FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_sr p2 ORDER BY p1.location.STX;

CREATE VIEW ContainTempGeomsr AS SELECT p1.location.STContains(p2.location) AS contain FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_sr p2 ORDER BY p1.location.STX;

CREATE VIEW equals_opgeomsr AS SELECT p1.location AS point FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_sr p2 WHERE p1.location = p2.location ORDER BY p1.location.STX;

CREATE VIEW notequal_opgeomsr AS SELECT p1.location AS point FROM GEOSPATIALPOINTGEOM_dt p1 CROSS JOIN GEOSPATIALPOINTGEOM_sr p2 WHERE p1.location <> p2.location ORDER BY p1.location.STX;


