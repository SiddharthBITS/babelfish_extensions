SELECT 
CASE 
    WHEN OBJECT_ID('pk_id') = OBJECT_ID('pk_id', 'pk')
    THEN 'Match'
    ELSE 'No Match'
END AS Result;
GO
~~START~~
varchar
Match
~~END~~


