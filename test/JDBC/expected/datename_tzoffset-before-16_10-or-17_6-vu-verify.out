GO
~~START~~
text
0
~~END~~

SELECT test_result FROM datename_tzoffset_different_test_scenarios WHERE test_input = 'datename(TZOFFSET, CAST(''2025-06-03 14:30:15'' AS DATETIMEOFFSET))';
GO
