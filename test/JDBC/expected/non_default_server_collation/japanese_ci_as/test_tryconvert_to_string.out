-- Tables with Check Constraints for Integer Types
CREATE TABLE try_convert_check_integers (
    ID INT IDENTITY(1,1),
    IntValue INT,
    -- Ensure string representation is not longer than 5 characters
    CONSTRAINT CHK_IntLength CHECK (LEN(TRY_CONVERT(VARCHAR(20), IntValue)) <= 5),
    -- Ensure string representation starts with a digit
    CONSTRAINT CHK_IntStartsWithDigit CHECK (LEFT(TRY_CONVERT(VARCHAR(20), IntValue), 1) LIKE '[0-9]'),
    -- Ensure no negative numbers (checking string representation)
    CONSTRAINT CHK_IntNotNegative CHECK (LEFT(TRY_CONVERT(VARCHAR(20), IntValue), 1) <> '-')
);
GO

-- Tables with Check Constraints for Decimal Types
CREATE TABLE try_convert_check_decimals (
    ID INT IDENTITY(1,1),
    DecimalValue DECIMAL(18,2),
    MoneyValue MONEY,
    
    -- Ensure decimal has exactly 2 decimal places in string representation
    CONSTRAINT CHK_DecimalFormat CHECK (
        TRY_CONVERT(VARCHAR(20), DecimalValue) LIKE '%.%' AND
        LEN(SUBSTRING(TRY_CONVERT(VARCHAR(20), DecimalValue), 
            CHARINDEX('.', TRY_CONVERT(VARCHAR(20), DecimalValue)) + 1, 20)) = 2
    ),
    
    -- Ensure money value formatted with style 1 is less than 10 characters
    CONSTRAINT CHK_MoneyLength CHECK (LEN(TRY_CONVERT(VARCHAR(20), MoneyValue, 1)) < 10)
);
GO

-- Tables with Check Constraints for DateTime Types
CREATE TABLE try_convert_check_datetime (
    ID INT IDENTITY(1,1),
    DateTimeValue DATETIME,
    
    -- Ensure date is after 2000 using string comparison
    CONSTRAINT CHK_DateTime2000 CHECK (
        TRY_CONVERT(VARCHAR(10), DateTimeValue, 120) >= '2000-01-01'
    ),
    
    -- Ensure time part is during business hours (09:00-17:00)
    CONSTRAINT CHK_BusinessHours CHECK (
        TRY_CONVERT(VARCHAR(8), DateTimeValue, 108) >= '09:00:00' AND
        TRY_CONVERT(VARCHAR(8), DateTimeValue, 108) <= '17:00:00'
    ),
    
    -- Ensure it's not a weekend using try_converted date
    CONSTRAINT CHK_NotWeekend CHECK (
        DATEPART(WEEKDAY, TRY_CONVERT(DATE, TRY_CONVERT(VARCHAR(10), DateTimeValue, 120))) NOT IN (1, 7)
    )
);
GO

-- Tables with Check Constraints for Binary Types
CREATE TABLE try_convert_check_binary (
    ID INT IDENTITY(1,1),
    BinaryValue BINARY(4),
    
    -- Ensure hex representation starts with '41' (letter 'A')
    CONSTRAINT CHK_BinaryStartsWithA CHECK (
        LEFT(TRY_CONVERT(VARCHAR(20), BinaryValue, 1), 4) = '0x41'
    ),
    
    -- Ensure binary representation is exactly 32 bits
    CONSTRAINT CHK_BinaryLength CHECK (
        LEN(TRY_CONVERT(VARCHAR(50), BinaryValue, 2)) = 32
    )
);
GO

-- Tables with Check Constraints for Special Types
CREATE TABLE try_convert_check_special (
    ID INT IDENTITY(1,1),
    UniqueidValue UNIQUEIDENTIFIER,
    XmlValue XML,
    GeometryValue GEOMETRY,
    GeographyValue GEOGRAPHY,
    SqlVariantValue SQL_VARIANT,
    
    CONSTRAINT CHK_Uniqueid_Format CHECK (
        TRY_CONVERT(VARCHAR(36), UniqueidValue) LIKE 
        '[0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F]-' +
        '[0-9A-F][0-9A-F][0-9A-F][0-9A-F]-' +
        '[0-9A-F][0-9A-F][0-9A-F][0-9A-F]-' +
        '[0-9A-F][0-9A-F][0-9A-F][0-9A-F]-' +
        '[0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F][0-9A-F]'
    ),
    
    CONSTRAINT CHK_Xml_WellFormed CHECK (
        TRY_CONVERT(NVARCHAR(MAX), XmlValue) LIKE '<%>%</%>' AND
        DATALENGTH(TRY_CONVERT(NVARCHAR(MAX), XmlValue)) > 0
    ),
    
    CONSTRAINT CHK_Geometry_Valid CHECK (
        TRY_CONVERT(VARCHAR(MAX), GeometryValue) LIKE 'POINT%' OR
        TRY_CONVERT(VARCHAR(MAX), GeometryValue) LIKE 'LINESTRING%' OR
        TRY_CONVERT(VARCHAR(MAX), GeometryValue) LIKE 'POLYGON%'
    ),
    
    CONSTRAINT CHK_Geography_Valid CHECK (
        TRY_CONVERT(VARCHAR(MAX), GeographyValue) LIKE 'POINT%' OR
        TRY_CONVERT(VARCHAR(MAX), GeographyValue) LIKE 'LINESTRING%' OR
        TRY_CONVERT(VARCHAR(MAX), GeographyValue) LIKE 'POLYGON%'
    ),
    
    CONSTRAINT CHK_SqlVariant_Valid CHECK (
        DATALENGTH(TRY_CONVERT(VARCHAR(MAX), SqlVariantValue)) > 0 AND
        LEN(TRY_CONVERT(VARCHAR(MAX), SqlVariantValue)) <= 8000
    )
);
GO




