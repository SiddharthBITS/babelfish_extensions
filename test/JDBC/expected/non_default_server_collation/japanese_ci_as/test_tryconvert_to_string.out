-- Table with Computed Columns for Integer Types
CREATE TABLE try_convert_computed_integers (
    ID INT IDENTITY(1,1),
    IntValue INT,
    BigintValue BIGINT,
    SmallintValue SMALLINT,
    TinyintValue TINYINT,
    BitValue BIT,
    
    -- Computed columns with CHAR conversion
    IntToChar AS TRY_CONVERT(CHAR(20), IntValue) PERSISTED,
    BigintToChar AS TRY_CONVERT(CHAR(20), BigintValue) PERSISTED,
    
    -- Computed columns with VARCHAR conversion
    IntToVarchar AS TRY_CONVERT(VARCHAR(20), IntValue) PERSISTED,
    SmallintToVarchar AS TRY_CONVERT(VARCHAR(20), SmallintValue) PERSISTED,
    
    -- Computed columns with NVARCHAR conversion
    TinyintToNVarchar AS TRY_CONVERT(NVARCHAR(20), TinyintValue) PERSISTED,
    BitToNVarchar AS TRY_CONVERT(NVARCHAR(20), BitValue) PERSISTED
);
GO
