-- =============================================
-- Dependent objects
-- =============================================
-- Create View that tests conversion of Integer Types to String Types
CREATE VIEW try_convert_view_integers AS
SELECT 
    IntCol,
    -- CHAR conversions
    TRY_CONVERT(CHAR(20), IntCol) AS IntToChar,
    TRY_CONVERT(CHAR(20), BigintCol) AS BigintToChar,
    TRY_CONVERT(CHAR(20), SmallintCol) AS SmallintToChar,
    TRY_CONVERT(CHAR(20), TinyintCol) AS TinyintToChar,
    TRY_CONVERT(CHAR(20), BitCol) AS BitToChar,
    
    -- VARCHAR conversions
    TRY_CONVERT(VARCHAR(20), IntCol) AS IntToVarchar,
    TRY_CONVERT(VARCHAR(20), BigintCol) AS BigintToVarchar,
    TRY_CONVERT(VARCHAR(20), SmallintCol) AS SmallintToVarchar,
    TRY_CONVERT(VARCHAR(20), TinyintCol) AS TinyintToVarchar,
    TRY_CONVERT(VARCHAR(20), BitCol) AS BitToVarchar,
    
    -- NCHAR conversions
    TRY_CONVERT(NCHAR(20), IntCol) AS IntToNChar,
    TRY_CONVERT(NCHAR(20), BigintCol) AS BigintToNChar,
    TRY_CONVERT(NCHAR(20), SmallintCol) AS SmallintToNChar,
    TRY_CONVERT(NCHAR(20), TinyintCol) AS TinyintToNChar,
    TRY_CONVERT(NCHAR(20), BitCol) AS BitToNChar,
    
    -- NVARCHAR conversions
    TRY_CONVERT(NVARCHAR(20), IntCol) AS IntToNVarchar,
    TRY_CONVERT(NVARCHAR(20), BigintCol) AS BigintToNVarchar,
    TRY_CONVERT(NVARCHAR(20), SmallintCol) AS SmallintToNVarchar,
    TRY_CONVERT(NVARCHAR(20), TinyintCol) AS TinyintToNVarchar,
    TRY_CONVERT(NVARCHAR(20), BitCol) AS BitToNVarchar
FROM try_convert_source_t1;
GO

-- Create View for Decimal Types conversions
CREATE VIEW try_convert_view_decimals AS
SELECT 
    -- CHAR conversions
    TRY_CONVERT(CHAR(30), DecimalCol) AS DecimalToChar,
    TRY_CONVERT(CHAR(30), NumericCol) AS NumericToChar,
    TRY_CONVERT(CHAR(30), FloatCol) AS FloatToChar,
    TRY_CONVERT(CHAR(30), RealCol) AS RealToChar,
    TRY_CONVERT(CHAR(30), MoneyCol) AS MoneyToChar,
    TRY_CONVERT(CHAR(30), SmallmoneyCol) AS SmallmoneyToChar,
    
    -- VARCHAR conversions with different styles
    TRY_CONVERT(VARCHAR(30), MoneyCol, 0) AS MoneyToVarchar_Style0,
    TRY_CONVERT(VARCHAR(30), MoneyCol, 1) AS MoneyToVarchar_Style1,
    TRY_CONVERT(VARCHAR(30), MoneyCol, 2) AS MoneyToVarchar_Style2,
    
    -- NVARCHAR conversions for floating point
    TRY_CONVERT(NVARCHAR(30), FloatCol) AS FloatToNVarchar,
    TRY_CONVERT(NVARCHAR(30), RealCol) AS RealToNVarchar
FROM try_convert_source_t1;
GO

-- Create View for DateTime Types conversions
CREATE VIEW try_convert_view_datetimes AS
SELECT 
    -- Default style conversions
    TRY_CONVERT(CHAR(30), DatetimeCol) AS DatetimeToChar,
    TRY_CONVERT(VARCHAR(30), DateCol) AS DateToVarchar,
    TRY_CONVERT(NCHAR(30), TimeCol) AS TimeToNChar,
    TRY_CONVERT(NVARCHAR(30), Datetime2Col) AS Datetime2ToNVarchar,
    
    -- Style 101 (mm/dd/yyyy) conversions
    TRY_CONVERT(VARCHAR(30), DatetimeCol, 101) AS DatetimeToVarchar_101,
    TRY_CONVERT(VARCHAR(30), DateCol, 101) AS DateToVarchar_101,
    TRY_CONVERT(VARCHAR(30), Datetime2Col, 101) AS Datetime2ToVarchar_101,
    
    -- Style 120 (ODBC canonical) conversions
    TRY_CONVERT(VARCHAR(30), DatetimeCol, 120) AS DatetimeToVarchar_120,
    TRY_CONVERT(VARCHAR(30), Datetime2Col, 120) AS Datetime2ToVarchar_120,
    
    -- Time-specific formats
    TRY_CONVERT(VARCHAR(30), TimeCol, 108) AS TimeToVarchar_108,
    TRY_CONVERT(VARCHAR(30), TimeCol, 114) AS TimeToVarchar_114
FROM try_convert_source_t1;
GO

-- Create View for Binary Types conversions
CREATE VIEW try_convert_view_binary AS
SELECT 
    -- Style 0 conversions (default)
    TRY_CONVERT(VARCHAR(50), BinaryCol, 0) AS BinaryToVarchar_0,
    TRY_CONVERT(VARCHAR(50), VarbinaryCol, 0) AS VarbinaryToVarchar_0,
    TRY_CONVERT(VARCHAR(50), ImageCol, 0) AS ImageToVarchar_0,
    
    -- Style 1 conversions (with 0x prefix)
    TRY_CONVERT(VARCHAR(50), BinaryCol, 1) AS BinaryToVarchar_1,
    TRY_CONVERT(VARCHAR(50), VarbinaryCol, 1) AS VarbinaryToVarchar_1,
    TRY_CONVERT(VARCHAR(50), ImageCol, 1) AS ImageToVarchar_1,
    
    -- Style 2 conversions (binary format)
    TRY_CONVERT(VARCHAR(50), BinaryCol, 2) AS BinaryToVarchar_2,
    TRY_CONVERT(VARCHAR(50), VarbinaryCol, 2) AS VarbinaryToVarchar_2,
    TRY_CONVERT(VARCHAR(50), ImageCol, 2) AS ImageToVarchar_2
FROM try_convert_source_t1;
GO

-- Create View for Special Types conversions
CREATE VIEW try_convert_view_special AS
SELECT 
    TRY_CONVERT(VARCHAR(40), UniqueidCol) AS GuidToVarchar,
    TRY_CONVERT(NVARCHAR(MAX), XmlCol) AS XmlToNVarchar,
    TRY_CONVERT(VARCHAR(MAX), GeometryCol) AS GeometryToVarchar,
    TRY_CONVERT(VARCHAR(MAX), GeographyCol) AS GeographyToVarchar,
    TRY_CONVERT(VARCHAR(50), SqlvariantCol) AS SqlvariantToVarchar
FROM try_convert_source_t1;
GO


