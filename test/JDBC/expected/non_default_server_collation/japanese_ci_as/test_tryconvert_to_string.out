    XmlToNvarcharMax AS TRY_CONVERT(NVARCHAR(MAX), XmlValue) PERSISTED,
    -- With style 1 (strip whitespace)
    XmlToVarcharStripped AS TRY_CONVERT(VARCHAR(MAX), XmlValue, 1) PERSISTED,
    
