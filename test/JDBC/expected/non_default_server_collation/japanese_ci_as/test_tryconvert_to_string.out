




-- =============================================
-- Expicit Casting using Try_Convert Function
-- =============================================
-- Create table with all data types
CREATE TABLE try_convert_source_t1 (
    -- Integer Types
    IntCol INT,
    BigintCol BIGINT,
    SmallintCol SMALLINT,
    TinyintCol TINYINT,
    BitCol BIT,
    -- Decimal Types
    DecimalCol DECIMAL(18,2),
    NumericCol NUMERIC(18,2),
    FloatCol FLOAT,
    RealCol REAL,
    MoneyCol MONEY,
    SmallmoneyCol SMALLMONEY,
    -- Date/Time Types
    DatetimeCol DATETIME,
    DateCol DATE,
    TimeCol TIME,
    Datetime2Col DATETIME2,
    SmalldatetimeCol SMALLDATETIME,
    DatetimeoffsetCol DATETIMEOFFSET,
    -- String Types
    CharCol CHAR(10),
    VarcharCol VARCHAR(50),
    NcharCol NCHAR(10),
    NvarcharCol NVARCHAR(50),
    TextCol TEXT,
    NtextCol NTEXT,
    -- Binary and Other Types
    BinaryCol BINARY(10),
    VarbinaryCol VARBINARY(50),
    ImageCol IMAGE,
    UniqueidCol UNIQUEIDENTIFIER,
    XmlCol XML,
    GeometryCol GEOMETRY,
    GeographyCol GEOGRAPHY,
    SqlvariantCol SQL_VARIANT
);
GO

-- Integer Types
CREATE TYPE udt_int FROM INT;
CREATE TYPE udt_bigint FROM BIGINT;
CREATE TYPE udt_smallint FROM SMALLINT;
CREATE TYPE udt_tinyint FROM TINYINT;
CREATE TYPE udt_bit FROM BIT;
GO

-- Decimal Types
CREATE TYPE udt_decimal FROM DECIMAL(18,2);
CREATE TYPE udt_numeric FROM NUMERIC(18,2);
CREATE TYPE udt_float FROM FLOAT;
CREATE TYPE udt_real FROM REAL;
CREATE TYPE udt_money FROM MONEY;
CREATE TYPE udt_smallmoney FROM SMALLMONEY;
GO

-- Date/Time Types
CREATE TYPE udt_datetime FROM DATETIME;
CREATE TYPE udt_date FROM DATE;
CREATE TYPE udt_time FROM TIME;
CREATE TYPE udt_datetime2 FROM DATETIME2;
CREATE TYPE udt_smalldatetime FROM SMALLDATETIME;
CREATE TYPE udt_datetimeoffset FROM DATETIMEOFFSET;
GO

-- String Types
CREATE TYPE udt_char FROM CHAR(10);
CREATE TYPE udt_varchar FROM VARCHAR(50);
CREATE TYPE udt_nchar FROM NCHAR(10);
CREATE TYPE udt_nvarchar FROM NVARCHAR(50);
CREATE TYPE udt_text FROM TEXT;
CREATE TYPE udt_ntext FROM NTEXT;
GO

-- Binary and Other Types
CREATE TYPE udt_binary FROM BINARY(10);
CREATE TYPE udt_varbinary FROM VARBINARY(50);
CREATE TYPE udt_image FROM IMAGE;
CREATE TYPE udt_uniqueidentifier FROM UNIQUEIDENTIFIER;
CREATE TYPE udt_sqlvariant FROM SQL_VARIANT;
GO





-- Create table with UDT columns
CREATE TABLE try_convert_source_udt_t1 (
    -- Integer Types
    IntCol udt_int,
    BigintCol udt_bigint,
    SmallintCol udt_smallint,
    TinyintCol udt_tinyint,
    BitCol udt_bit,
    -- Decimal Types
    DecimalCol udt_decimal,
    NumericCol udt_numeric,
    FloatCol udt_float,
    RealCol udt_real,
    MoneyCol udt_money,
    SmallmoneyCol udt_smallmoney,
    -- Date/Time Types
    DatetimeCol udt_datetime,
    DateCol udt_date,
    TimeCol udt_time,
    Datetime2Col udt_datetime2,
    SmalldatetimeCol udt_smalldatetime,
    DatetimeoffsetCol udt_datetimeoffset,
    -- String Types
    CharCol udt_char,
    VarcharCol udt_varchar,
    NcharCol udt_nchar,
    NvarcharCol udt_nvarchar,
    TextCol udt_text,
    NtextCol udt_ntext,
    -- Binary and Other Types
    BinaryCol udt_binary,
    VarbinaryCol udt_varbinary,
    ImageCol udt_image,
    UniqueidCol udt_uniqueidentifier,
    SqlvariantCol udt_sqlvariant
);
GO

-- Insert test data
INSERT INTO try_convert_source_t1 VALUES (
    -- Integer Types
    123, 123456789, 12345, 255, 1,
    
    -- Decimal Types
    123.45, 123.45, 123.45, 123.45, 123.45, 123.45,
    
    -- Date/Time Types
    '2024-01-15 12:34:56', '2024-01-15', '12:34:56',
    '2024-01-15 12:34:56.1234567', '2024-01-15 12:34:00',
    '2024-01-15 12:34:56.1234567 +00:00',
    
    -- String Types
    'Test', 'Test String', N'Test', N'Test String',
    'Test Text', N'Test NText',
    
    -- Binary and Other Types
    0x4142434445, 0x4142434445, 0x4142434445,
    '9641D381-A27F-40A0-8FB9-42216F635D4A', '<note>
                    <to>John   Doe</to>
                    <from>Jane	Smith</from>
                    <heading>
                        Reminder
                    </heading>
                    <body>Meeting at    3 PM</body>
                </note>',
    geometry::STGeomFromText('POINT (3 4)', 0),
    geography::STGeomFromText('POINT(-122.34900 47.65100)', 4326),
    123
);
GO
