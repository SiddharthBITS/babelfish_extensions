-- =============================================
-- Expicit Casting using Try_Convert Function with Style Parameter: Binary, Varbinary and Image
-- =============================================
-- Create test table
CREATE TABLE try_convert_binary_source (
    ID INT PRIMARY KEY,
    BinaryCol BINARY(10),
    VarbinaryCol VARBINARY(50),
    ImageCol IMAGE,
    Description VARCHAR(100)
);
GO

-- Create test table with UDT columns
CREATE TABLE try_convert_binary_source_udt (
    ID INT PRIMARY KEY,
    BinaryCol udt_binary,
    VarbinaryCol udt_varbinary,
    ImageCol udt_image,
    Description VARCHAR(100)
);
GO

-- Insert test data
INSERT INTO try_convert_binary_source VALUES
-- Basic binary data
(1, 0x41424344, 0x41424344, 0x41424344, 'Simple ABCD'),
-- Zeros
(2, 0x00000000, 0x00000000, 0x00000000, 'All zeros'),
-- Mixed hex values
(3, 0x41424300, 0x41424300, 0x41424300, 'ABC with trailing zero'),
-- Max values
(4, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 'All F values'),
-- SQL Server string 'SQL'
(5, 0x53514C00, 0x53514C00, 0x53514C00, 'SQL with trailing zero'),
-- Mixed values
(6, 0x4142FF00, 0x4142FF00, 0x4142FF00, 'AB with FF and trailing zero');
GO
~~ROW COUNT: 6~~


