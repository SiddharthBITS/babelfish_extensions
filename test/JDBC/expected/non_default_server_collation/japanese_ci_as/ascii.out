-- 6. Multiple Character String Tests
SELECT 
    ASCII('ABC') AS FirstCharOfABC,
    ASCII('123') AS FirstCharOf123,
    ASCII('!@#') AS FirstCharOfSpecial,
    ASCII('   ABC') AS FirstCharOfSpacedString,
    ASCII(CHAR(13) + 'ABC') AS FirstCharOfCRString;
GO
