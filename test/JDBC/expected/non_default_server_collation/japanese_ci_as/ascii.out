-- 7. Unicode Character Tests
SELECT 
    UnicodeChar,
    UnicodeString,
    ASCII(UnicodeChar) AS CharASCII,
    ASCII(UnicodeString) AS StringASCII,
    ExpectedValue,
    CASE 
        WHEN ASCII(UnicodeChar) = ExpectedValue THEN 'Pass'
        ELSE 'Fail'
    END AS TestResult
FROM ascii_t2;
GO
