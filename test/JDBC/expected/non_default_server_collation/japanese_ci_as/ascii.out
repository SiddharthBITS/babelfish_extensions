-- =============================================
-- ADVANCED TEST CASES
-- =============================================
-- 9. Character Range Tests
WITH Numbers AS (
    SELECT generate_series AS Num
    FROM GENERATE_SERIES(1, 255)
)
SELECT 
    Num,
    CHAR(Num) AS CharacterValue,
    ASCII(CHAR(Num)) AS ASCIIValue,
    CASE 
        WHEN ASCII(CHAR(Num)) = Num THEN 'Pass'
        ELSE 'Fail'
    END AS TestResult
FROM Numbers;
GO
