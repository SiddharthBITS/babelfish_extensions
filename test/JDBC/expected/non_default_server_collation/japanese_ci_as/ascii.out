SELECT 
    ASCII(IntValue) AS IntToASCII,
    ASCII(FloatValue) AS FloatToASCII,
    ASCII(DateValue) AS DateToASCII,
    ASCII(BinaryValue) AS BinaryToASCII
FROM ascii_conversion_t3;
GO
