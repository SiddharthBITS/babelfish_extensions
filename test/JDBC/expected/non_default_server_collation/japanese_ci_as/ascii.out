~~END~~


-- 5. NULL and Empty String Tests
SELECT 
    ASCII(NULL) AS NullInput,
    ASCII('') AS EmptyString,
    ASCII('  ') AS MultipleSpaces,
    ASCII(CAST(NULL AS VARCHAR)) AS NullVarchar,
    ASCII(CAST(NULL AS NVARCHAR)) AS NullNVarchar;
GO
