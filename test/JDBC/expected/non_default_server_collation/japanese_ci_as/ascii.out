-- 8. Edge Case Tests
SELECT 
    -- Extended ASCII characters (128-255)
    ASCII(CHAR(128)) AS Char128,
    ASCII(CHAR(255)) AS Char255,
    
    -- Control characters
    ASCII(CHAR(1)) AS StartOfHeading,
    ASCII(CHAR(31)) AS UnitSeparator
GO
