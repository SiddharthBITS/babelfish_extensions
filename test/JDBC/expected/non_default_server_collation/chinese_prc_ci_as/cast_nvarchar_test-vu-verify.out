~~END~~

-- Create a view
CREATE VIEW dbo.HashedDataView1
AS
SELECT 
    ID,
    Data,
    dbo.hashbytes('SHA2_256', Data) AS HashedData
FROM hashbytes_table;
GO

SELECT * FROM dbo.HashedDataView1;
GO
