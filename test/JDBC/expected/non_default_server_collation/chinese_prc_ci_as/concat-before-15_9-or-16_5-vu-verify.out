GO
~~START~~
varchar
|  abc?defghi??                                    ab?x?y|
~~END~~


DECLARE @inputString CHAR(50) = '  abc🙂defghi🙂🙂    '
SELECT '|' + CONCAT(@inputString, 'ab?', 'x🙂y') + '|'
GO
~~START~~
varchar
|  abc?defghi??                                    ab?x?y|
~~END~~


DECLARE @inputString CHAR(50) = '  比尔·拉莫斯    '
