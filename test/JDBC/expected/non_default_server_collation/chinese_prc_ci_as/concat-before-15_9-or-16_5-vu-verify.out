varchar
|  比尔·拉莫斯                                    比拉斯    比拉斯    |
~~END~~


DECLARE @inputString CHAR(50) = '  比尔·拉莫斯    ', @inputString1 CHAR(10) = '比拉斯 ', @inputString2 CHAR(10) = '比拉斯 '
SELECT '|' + CONCAT(@inputString, @inputString1, @inputString2) COLLATE CHINESE_PRC_CI_AS + '|'
GO
