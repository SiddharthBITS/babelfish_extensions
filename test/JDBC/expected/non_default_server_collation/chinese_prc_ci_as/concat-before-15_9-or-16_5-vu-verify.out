-- different no. of arguments
select CONCAT('a')
GO
~~START~~
varchar
a
~~END~~

select 1  select concat('a') select 2
GO
~~START~~
int
1
~~END~~

~~START~~
varchar
a
~~END~~

~~START~~
int
2
~~END~~

select concat()
GO
~~START~~
varchar
