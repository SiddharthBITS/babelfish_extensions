-- GO
-- FUNCTION
CREATE FUNCTION BABEL_5608_vu_prepare_t12_fun1
(
    @pattern varchar(100)
)
RETURNS TABLE
AS
RETURN
(
    SELECT * FROM BABEL_5608_vu_prepare_t12_2
    WHERE status LIKE @pattern
);
GO

-- PROCEDURE
CREATE PROCEDURE BABEL_5608_vu_prepare_t12_proc1
    @pattern varchar(100)
AS
BEGIN
    SET NOCOUNT ON;
    
    SELECT * FROM BABEL_5608_vu_prepare_t12_2
    WHERE status LIKE @pattern
END;
GO


