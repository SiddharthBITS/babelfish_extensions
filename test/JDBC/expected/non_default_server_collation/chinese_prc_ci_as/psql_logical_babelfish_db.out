show psql_logical_babelfish_db_name;
go
~~START~~
text

~~END~~


-- set the GUC to master
set psql_logical_babelfish_db_name = 'master';
go

-- check whether the GUC has been set to master
show psql_logical_babelfish_db_name;
go
~~START~~
text
master
~~END~~


