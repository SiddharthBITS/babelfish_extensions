    CASE WHEN COUNT(*) = 3 THEN 'PASS' ELSE 'FAIL' END AS LeftJoinTest
FROM #Orders o
LEFT JOIN #Shipments s ON o.OrderID = s.OrderID
WHERE DATEDIFF(DAY, 
      TODATETIMEOFFSET(o.OrderDate, '+00:00'), 
      TODATETIMEOFFSET(s.ShipmentDate, '+00:00')) BETWEEN 0 AND 10;
