-- Test 11: Using DATEDIFF with GROUP BY, HAVING, ORDER BY, SELECT, WHERE
CREATE TABLE #TransactionData (
    ID INT PRIMARY KEY,
    TransactionDate DATETIME,
    Amount DECIMAL(10,2)
);
