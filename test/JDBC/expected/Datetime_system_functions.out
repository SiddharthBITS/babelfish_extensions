DECLARE @OffsetStr VARCHAR(10) = '-' + CAST(ABS(@BaseOffset) AS VARCHAR(2)) + ':00';
SELECT
    CASE WHEN SWITCHOFFSET(@DateTimeOffset, @OffsetStr) = '2023-01-01 02:00:00.0000000 -10:00' THEN 'PASS' ELSE 'FAIL' END AS ExpressionTest;
