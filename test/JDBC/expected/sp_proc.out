use db1
go
create schema s1
go
    create login non_default_schema_login with password = '12345678'
go
create user non_default_schema_login
go
alter user non_default_schema_login with default_schema = s1
go
create proc s1.sp_user_proc as select '--- S1 ---';
go
create proc dbo.sp_user_proc as select '--- DBO ---';
go
alter role db_owner add member non_default_schema_login
go

-- tsql user=non_default_schema_login password=12345678 database=db1
select schema_name(), db_name()
go
~~START~~
varchar#!#nvarchar
s1#!#db1
~~END~~

-- should resolve to s1.sp_user_proc
exec sp_user_proc
exec db1..sp_user_proc
go
