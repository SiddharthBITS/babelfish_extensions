-- CEILING and FLOOR
SELECT
	CEILING(tinyint_col + 0.5) AS ceil_tinyint,
	CEILING(smallint_col + 0.5) AS ceil_smallint,
	CEILING(integer_col + 0.5) AS ceil_int,
	CEILING(bigint_col + 0.5) AS ceil_bigint
FROM exactnumeric_table;
