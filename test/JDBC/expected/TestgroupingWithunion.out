-- TINYINT to REAL
CREATE TABLE t_tinyint_real(a tinyint);
GO
INSERT INTO t_tinyint_real VALUES (1), (1), (2);
GO
~~ROW COUNT: 3~~

SELECT a as num_val, COUNT(a) as count, AVG(a) as avg 
FROM t_tinyint_real GROUP BY a 
UNION 
SELECT cast(3.0 as real) as num_cal, 1, 1
ORDER BY num_val;
GO
~~START~~
real#!#int#!#int
1.0#!#2#!#1
2.0#!#1#!#2
3.0#!#1#!#1
~~END~~


