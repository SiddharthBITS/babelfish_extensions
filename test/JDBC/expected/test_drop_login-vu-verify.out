-- tsql
-- reset login password
ALTER LOGIN babel_5127_test_sysadmin WITH PASSWORD = 'abc';
GO

ALTER LOGIN babel_5127_test_securityadmin WITH PASSWORD = 'abc';
GO

ALTER LOGIN babel_5127_test_regularuser WITH PASSWORD = 'abc';
GO

-- 1. Test with master user, should still fail
DROP LOGIN [public];
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Cannot drop the login 'public', because it does not exist or you do not have permission.)~~


DROP USER [public];
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Cannot drop the user 'public', because it does not exist or you do not have permission.)~~


DROP ROLE [public];
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: Cannot drop the role 'public', because it does not exist or you do not have permission.)~~


