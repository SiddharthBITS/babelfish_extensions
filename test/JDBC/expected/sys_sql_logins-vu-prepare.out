-- tsql
CREATE LOGIN sys_sql_logins_vu_login1 with password = '123'
GO

CREATE LOGIN sys_sql_logins_vu_login2 with password = '123'
GO

CREATE LOGIN sys_sql_logins_vu_login3 with password = '123'
GO

CREATE VIEW sys_sql_logins_vu_prepare_view AS
    SELECT 
        sq.name, 
        sq.type_desc, 
        sq.is_policy_checked, 
        sq.is_expiration_checked, 
        sq.password_hash
    FROM sys.sql_logins AS sq
    WHERE sq.name like 'sys_sql_logins_vu_login%' OR sq.name IN ('jdbc_user','public','sysadmin','securityadmin','dbcreator','bbf_role_admin')
    ORDER BY sq.name;
GO

GRANT SELECT ON dbo.sys_sql_logins_vu_prepare_view TO PUBLIC;
GO
