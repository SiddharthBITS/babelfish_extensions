GO

INSERT INTO dbo.my_babel_cross_db_vu_prepare_db1_t2 (a)
SELECT t1.a
FROM master.dbo.babel_cross_db_vu_prepare_master_t1 t1
JOIN dbo.babel_cross_db_vu_prepare_db1_t1 t2 ON t1.a = t2.a;
