create procedure p6_atatuservar @@p4 int output
as
set @@p4 *= 2
select @@p4
return @@p4*-1
go
declare @#v1 int, @@v2 int = 123
exec @#v1 = p6_atatuservar @@v2
select @#v1, @@v2
go
~~START~~
int
246
~~END~~

~~START~~
int#!#int
-246#!#123
~~END~~


declare @#v1 int, @@v2 int = 123
exec @#v1 = p6_atatuservar @@p4 = @@v2 out
select @#v1, @@v2
go
~~START~~
int
246
~~END~~

~~START~~
int#!#int
-246#!#246
~~END~~


create procedure p7_atatuservar
as
declare @#v1 int, @@v2 int = 123
exec @#v1 = p6_atatuservar @@v2 output
select @#v1, @@v2
go

