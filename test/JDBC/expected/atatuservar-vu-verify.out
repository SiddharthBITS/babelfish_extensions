-- simple variables in T-SQL batch
set quoted_identifier off
go
declare @@v int = 2 select @@v
go
~~START~~
int
2
~~END~~

declare @#v int = 2 select @#v
go
~~START~~
int
2
~~END~~

declare @@@$$@@@@v int = 2 select @@@$$@@@@v
go
~~START~~
int
2
~~END~~

declare @@@$$@@@@v##### int = 2 select @@@$$@@@@v#####
go
~~START~~
int
2
~~END~~

declare @@@$$@@@@#####v int = 2 select @@@$$@@@@#####v
go
~~START~~
int
2
~~END~~

declare @#############v int = 2 select @#############v
go
~~START~~
int
2
~~END~~


