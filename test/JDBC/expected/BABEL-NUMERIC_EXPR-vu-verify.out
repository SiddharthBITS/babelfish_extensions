-- CTE with multiple levels and join
WITH 
cte1 AS (
    SELECT id, CAST(id AS INT) AS int_id
    FROM BABEL_5454_T10
),
cte2 AS (
    SELECT DISTINCT int_id
    FROM cte1
)
SELECT 
    c1.id,
    c2.int_id AS floor_id,
    c1.id * c2.int_id AS product
FROM cte1 c1
JOIN cte2 c2 ON c1.int_id = c2.int_id
ORDER BY c1.id, c2.int_id;
GO
