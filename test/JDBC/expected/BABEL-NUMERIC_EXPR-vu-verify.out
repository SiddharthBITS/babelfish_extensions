-- CTE with aggregation and outer join
WITH CTE AS (
    SELECT (id/10) AS group_id, AVG(id) AS avg_id 
    FROM BABEL_5454_T9 
    GROUP BY (id/10)
)
SELECT t.id, c.avg_id 
FROM BABEL_5454_T9 t 
LEFT JOIN CTE c ON (t.id/10) = c.group_id
WHERE t.id % 10 = 0
ORDER BY t.id
