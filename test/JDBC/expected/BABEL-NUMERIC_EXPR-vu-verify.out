    SELECT value1 + COL3_T2 AS sum_num
    FROM (
        SELECT COL2_T2 AS value1, COL3_T2
        FROM BABEL_5454_T1
        INNER JOIN BABEL_5454_T2 ON COL1_T2 = COL1_T1
        UNION ALL
        SELECT 1 AS aw, COL3_T1 AS aw1
        FROM BABEL_5454_T1
    ) a
    UNION ALL
    SELECT COL2_T2
    FROM BABEL_5454_T2
)
ORDER BY sum_num;
GO
