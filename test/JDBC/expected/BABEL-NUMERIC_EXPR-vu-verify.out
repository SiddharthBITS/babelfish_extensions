-- CTE with self-join and arithmetic operations
WITH CTE AS (
    SELECT id, id * 2 AS double_id, id * id AS squared_id
    FROM BABEL_5454_T10
)
SELECT 
    t1.id AS original_id,
    t1.double_id,
    t1.squared_id,
    t2.id AS next_id,
    t1.id + t2.id AS sum_ids
FROM CTE t1
LEFT JOIN CTE t2 ON t1.id < t2.id
ORDER BY t1.id
GO
