-- Query with CASE and UNION ALL
SELECT
    result + result AS sum_result
FROM (
    SELECT
        CASE
            WHEN 1 = 1 THEN CAST(1.12343 AS DECIMAL(5,2))
        END AS result
    UNION ALL
    SELECT COL3_T2
    FROM BABEL_5454_T2
) AS derived_table
ORDER BY sum_result
GO
