-- CTE with PIVOT-like operation
WITH CTE AS (
    SELECT id, 
           CASE WHEN id % 3 = 0 THEN 'Fizz'
                WHEN id % 5 = 0 THEN 'Buzz'
                ELSE 'Other' END AS category
    FROM BABEL_5454_T9
    WHERE id <= 30
)
SELECT 
    category,
    COUNT(*) AS count,
    STRING_AGG(CAST(id AS VARCHAR), ',') AS ids
FROM CTE
GROUP BY category
ORDER BY count
GO
