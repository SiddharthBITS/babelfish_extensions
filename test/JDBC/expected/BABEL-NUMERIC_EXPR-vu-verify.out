-- Nested CTEs with UNION ALL
WITH cte1 AS (
    SELECT id FROM BABEL_5454_T9 WHERE id <= 50
),
cte2 AS (
    SELECT id FROM BABEL_5454_T9 WHERE id > 50
),
combined AS (
    SELECT id, 'Lower' AS category FROM cte1
    UNION ALL
    SELECT id, 'Upper' AS category FROM cte2
)
SELECT category, AVG(id) AS avg_id
FROM combined
GROUP BY category
Order BY avg_id
GO
