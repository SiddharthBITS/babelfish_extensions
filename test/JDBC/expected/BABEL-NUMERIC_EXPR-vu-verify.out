-- Nested operator query
SELECT
    sum + COL3_T2 AS val
FROM (
    SELECT
        COL3_T1,
        COL2_T2 + COL3_T2 AS sum,
        COL2_T1 AS value2,
        COL2_T1,
        COL3_T2
    FROM BABEL_5454_T1
    INNER JOIN BABEL_5454_T2
        ON COL1_T2 = COL1_T1
    UNION ALL
    SELECT
        1 AS aw,
        1 AS aw1,
        COL2_T1 AS cr,
        COL2_T1,
        COL3_T1 AS aw1
    FROM BABEL_5454_T1
) a
ORDER BY val;
