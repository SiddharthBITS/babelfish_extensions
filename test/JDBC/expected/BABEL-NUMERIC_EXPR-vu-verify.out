WITH CTE AS (
    SELECT id, ROW_NUMBER() OVER (ORDER BY id) AS row_num 
    FROM BABEL_5454_T9 
    WHERE id <= 50
)
SELECT c1.id, c1.row_num, c2.id AS next_id 
FROM CTE c1 
LEFT JOIN CTE c2 ON c1.row_num = c2.row_num - 1
ORDER BY c1.row_num
