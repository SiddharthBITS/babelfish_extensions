0.00#!#1.00#!#0.00
~~END~~


-- CTE with window functions
WITH CTE AS (
    SELECT 
        id,
        ROW_NUMBER() OVER (ORDER BY id) AS row_num,
        NTILE(3) OVER (ORDER BY id) AS ntile,
        LAG(id) OVER (ORDER BY id) AS prev_id,
        LEAD(id) OVER (ORDER BY id) AS next_id
    FROM BABEL_5454_T10
)
SELECT *
FROM CTE
ORDER BY id
GO
