-- Testing for numeric and decimal
-- Test Case 1: Basic CASE with 6 columns and ELSE
SELECT CASE 3
   WHEN 1 THEN COL1 
   WHEN 2 THEN COL2
   WHEN 3 THEN COL3
   WHEN 4 THEN COL4
   WHEN 5 THEN COL5
   WHEN 6 THEN COL6
   ELSE 0
END AS RESULT 
FROM BABEL_5341_T1;
GO
~~START~~
numeric
1234567890123456789
9876543210987654321
1111111111111111111
3333333333333333333
5555555555555555555
~~END~~


