   WHEN 1 THEN CAST(12345.6789 AS DECIMAL(10,4))
   WHEN 2 THEN CAST(98765.4321 AS NUMERIC(12,4))
   WHEN 3 THEN CAST(1234567.89 AS DECIMAL(15,2))
   WHEN 4 THEN CAST(9.87654321 AS NUMERIC(9,8))
   ELSE CAST(0 AS DECIMAL(5,2))
END AS RESULT
GO
~~START~~
numeric
9.87654321
~~END~~


