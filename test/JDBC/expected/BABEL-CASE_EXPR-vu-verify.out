   WHEN 3 THEN CAST(CAST(1234567.8901234567890 AS BigNumericType_BABEL_5341) AS NumericType_BABEL_5341)
   WHEN 4 THEN CAST(CAST(99.99 AS SmallDecimalType_BABEL_5341) AS DecimalType_BABEL_5341)
