   WHEN 1 THEN CAST(1.23 AS NUMERIC(20,2))
   WHEN 2 THEN CAST('12:34:56' AS TIME)
END AS Result
GO
~~ERROR (Code: 33557097)~~

~~ERROR (Message: CASE/WHEN could not convert type time without time zone to numeric)~~


