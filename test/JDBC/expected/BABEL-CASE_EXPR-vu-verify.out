   WHEN 2 THEN CAST(99999999999999.9999 AS DecimalType_BABEL_5341)
   WHEN 3 THEN CAST(12345678901234567890.1234567890 AS BigNumericType_BABEL_5341)
   WHEN 4 THEN CAST(999.99 AS SmallDecimalType_BABEL_5341)
