-- COALESCE with timezone awareness
SELECT 
    ID,
    COALESCE(NullableDTOColumn, DTOColumn, '2023-01-01 00:00:00 +00:00') AS CoalescedDTO,
    Description
FROM DateTimeOffsetExpressionTest;
GO
