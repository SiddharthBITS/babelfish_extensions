~~END~~


-- Ignore index
SET STATISTICS IO ON;
SELECT * FROM DateTimeOffsetIndexTest WITH (INDEX(0))
WHERE DTOColumn = '2023-01-01 00:00:00 +00:00';
SET STATISTICS IO OFF;
GO
