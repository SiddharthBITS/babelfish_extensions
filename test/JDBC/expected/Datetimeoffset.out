-- Create test table for DATETIMEOFFSET
CREATE TABLE DateTimeOffsetIndexTest (
    ID INT IDENTITY PRIMARY KEY,
    DTOColumn DATETIMEOFFSET(7),
    DTOColumn2 DATETIMEOFFSET(7),
    Description NVARCHAR(100),
    NumericColumn INT
);
GO

