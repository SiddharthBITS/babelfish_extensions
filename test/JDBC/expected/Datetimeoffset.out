    BusinessDTOCol AT TIME ZONE 'Pacific Standard Time' AS PST,
    BusinessDTOCol AT TIME ZONE 'Eastern Standard Time' AS EST,
    DATEADD(HOUR, 1, BusinessDTOCol) AS AddHour
FROM UDDTDateTimeOffsetTest ORDER BY ID;
