~~END~~


-- 11. Test ordering and indexing
CREATE INDEX IX_BusinessDTO ON UDDTDateTimeOffsetTest(BusinessDTOCol);
CREATE INDEX IX_ShiftDTO ON UDDTDateTimeOffsetTest(ShiftDTOCol);
