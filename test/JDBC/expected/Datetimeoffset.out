-- Display results with detailed analysis
SELECT 
    ID,
    Description,
    DateTimeOffsetValue,
    Scale,
    Precision,
    StorageBytes,
    FractionalPrecision,
    FormattedValue,
    TimeZoneOffset,
    LEN(FormattedValue) AS FormattedLength,
    CASE 
        WHEN Scale <= 2 THEN '0-2 (8 bytes)'
        WHEN Scale <= 4 THEN '3-4 (9 bytes)'
        ELSE '5-7 (10 bytes)'
    END AS ScaleGroup
FROM DateTimeOffsetScaleTest
ORDER BY Scale, ID;
GO
