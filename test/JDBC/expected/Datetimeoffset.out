-- IIF statements with timezone awareness
SELECT 
    DTOColumn,
    IIF(DATEPART(HOUR, DATEADD(HOUR, DATEPART(TZOFFSET, DTOColumn), DTOColumn)) < 12, 'AM', 'PM') AS LocalAMPM,
    Description
FROM DateTimeOffsetExpressionTest ORDER BY ID;
GO
