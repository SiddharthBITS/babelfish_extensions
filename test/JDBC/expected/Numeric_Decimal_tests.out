    AS PARTITION NUMERIC_PRECISE_dt_partition_func ALL
    TO ([PRIMARY]);
GO

CREATE TABLE NUMERIC_PRECISE_dt_partition(
    amount NUMERIC(38,10),
    category VARCHAR(20)
)
ON NUMERIC_PRECISE_dt_partition_scheme(amount);
GO

