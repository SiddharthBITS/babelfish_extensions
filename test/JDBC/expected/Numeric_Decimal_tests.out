SELECT CASE 
    WHEN small_amount IS NULL AND large_amount IS NULL 
    AND exact_decimal IS NULL AND whole_number IS NULL THEN 'NULL test passed'
    ELSE 'NULL test failed'
END AS null_test_result
FROM udt_numeric_test WHERE id = 1;
GO
