-- Additional test for precision and scale variations
CREATE PARTITION FUNCTION NUMERIC_PRECISE_dt_partition_func (NUMERIC(38,10))
    AS RANGE RIGHT FOR VALUES(
        0.0000000000,
        1000.0000000000,
        10000.0000000000,
        100000.0000000000
    );
GO

