           WHEN CAST(0 AS BIT) = 1 THEN CAST(100 AS MONEY)
           WHEN CAST(1 AS BIT) = 1 THEN @large_num
           ELSE CAST(300.99 AS NUMERIC(10,2))
       END
ORDER BY source_type;
GO
