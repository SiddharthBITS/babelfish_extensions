GO

CREATE USER babel_5146_ddladmin_u FOR LOGIN babel_5146_ddladmin_l;
GO

CREATE USER babel_5146_case_u FOR LOGIN babel_5146_case_l;
GO

ALTER ROLE db_owner ADD MEMBER babel_5146_owner_u;
GO

ALTER ROLE db_ddladmin ADD MEMBER babel_5146_ddladmin_u;
GO

GRANT CONNECT TO guest;
GO

GRANT EXECUTE ON babel_5146_prepare_p1 TO guest;
GO

