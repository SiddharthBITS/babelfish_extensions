    WHEN (SELECT COUNT(*) FROM MyTable WHERE num_col > 3000) > 1 THEN (SELECT SUM(num_col) FROM MyTable)
    ELSE (SELECT AVG(dec_col) FROM MyTable)
END AS result;
GO
