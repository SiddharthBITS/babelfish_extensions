numeric
9876.54
2345.67
3456.78
~~END~~


-- Test Case 2
SELECT CASE 
    WHEN t.dec_col < 8000 THEN t.num_col
    ELSE t.dec_col
END AS result
FROM MyTable t
WHERE t.id = 2;
GO
~~START~~
numeric
8765.43
~~END~~


-- Test Case 3
