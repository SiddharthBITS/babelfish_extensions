200.0000#!#1
922337203685477.5807#!#1
100.0000#!#1
~~END~~


SELECT SmallMoneyVal, COUNT(*) as Count 
FROM MoneyComparisonTest 
GROUP BY SmallMoneyVal
HAVING SmallMoneyVal < 0;
GO
