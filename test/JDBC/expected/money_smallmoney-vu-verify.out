~~END~~


-- Correlated subqueries
SELECT ID, MoneyVal
FROM MoneyComparisonTest t1
WHERE MoneyVal > (
    SELECT AVG(CAST(t2.MoneyVal AS FLOAT))
    FROM MoneyComparisonTest t2
    WHERE t2.ID < t1.ID
);
GO
