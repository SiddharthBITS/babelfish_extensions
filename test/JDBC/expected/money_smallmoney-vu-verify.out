-- Union with comparisons
SELECT ID, MoneyVal, 'MONEY' as Type
FROM MoneyComparisonTest
WHERE MoneyVal > 0
UNION ALL
SELECT ID, SmallMoneyVal, 'SMALLMONEY' as Type
FROM MoneyComparisonTest
WHERE SmallMoneyVal > 0
ORDER BY MoneyVal, ID, Type;
