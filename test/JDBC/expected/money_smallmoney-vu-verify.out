       (CAST(100.00 AS SMALLMONEY) * 
        CASE 
            WHEN CAST(100.00 AS SMALLMONEY) > CAST(50.00 AS SMALLMONEY) 
            THEN CAST(0.10 AS FLOAT)
            ELSE CAST(0.05 AS FLOAT)
        END)
AS adjusted_price;
