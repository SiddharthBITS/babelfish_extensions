-- Exists with comparison
SELECT ID, MoneyVal
FROM MoneyComparisonTest t1
WHERE EXISTS (
    SELECT 1 
    FROM MoneyComparisonTest2 t2 
    WHERE t2.MoneyVal = t1.MoneyVal
);
