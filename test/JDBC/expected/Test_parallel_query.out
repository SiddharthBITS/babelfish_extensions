2#!#Jane#!#Smith#!#HR#!#65000.00#!#2025-01-01
3#!#Mike#!#Johnson#!#IT#!#70000.00#!#2025-01-01
~~END~~


DROP PROCEDURE UpdateEmployeeSalaries
GO

